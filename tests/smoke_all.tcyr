# smoke_all.tcyr -- full-unit integration smoke: every module compiled together,
# every synth + the mixer + a preset produces finite (and mostly energetic)
# audio. This is the compile gate for the whole library.

include "src/error.cyr"
include "src/logging.cyr"
include "src/dsp.cyr"
include "src/smooth.cyr"
include "src/event.cyr"
include "src/traits.cyr"
include "src/engine.cyr"
include "src/gear.cyr"
include "src/motor.cyr"
include "src/turbine.cyr"
include "src/clock.cyr"
include "src/transmission.cyr"
include "src/differential.cyr"
include "src/forced_induction.cyr"
include "src/belt_drive.cyr"
include "src/chain_drive.cyr"
include "src/mixer.cyr"
include "src/presets.cyr"

fn audio_all_finite(v) {
    var n = vec_len(v);
    if (n == 0) { return 0; }
    var i = 0;
    while (i < n) {
        if (ghurni_is_finite(vec_get(v, i)) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}
fn audio_has_energy(v) {
    if (audio_all_finite(v) == 0) { return 0; }
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        if (f64_gt(f64_abs(vec_get(v, i)), 0.001) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

alloc_init();
var SR = f64_from(44100);
var HALF = 0.5;

# ================================================================
test_group("every synth constructs + produces finite audio");

var eng = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, SR);
assert_eq(ghurni_is_err(eng), 0, "engine ok");
assert_eq(audio_has_energy(ghurni_engine_synthesize(eng, f64_from(3000), HALF, HALF)), 1, "engine energy");

var gr = ghurni_gear_new(32, GH_GEAR_STEEL, SR);
assert_eq(ghurni_is_err(gr), 0, "gear ok");
assert_eq(audio_all_finite(ghurni_gear_synthesize(gr, f64_from(1500), HALF)), 1, "gear finite");

var mo = ghurni_motor_new(GH_MOTOR_BRUSHLESS, 8, SR);
assert_eq(ghurni_is_err(mo), 0, "motor ok");
assert_eq(audio_all_finite(ghurni_motor_synthesize(mo, f64_from(3000), HALF, HALF)), 1, "motor finite");

var tu = ghurni_turbine_new(16, f64_from(500), SR);
assert_eq(ghurni_is_err(tu), 0, "turbine ok");
assert_eq(audio_has_energy(ghurni_turbine_synthesize(tu, f64_from(10000), HALF)), 1, "turbine energy");

var tuo = ghurni_turbine_new(3, 0, SR);
assert_eq(audio_has_energy(ghurni_turbine_synthesize(tuo, f64_from(2000), HALF)), 1, "open turbine energy");

var cl = ghurni_clock_new(GH_CLOCK_GRANDFATHER_CLOCK, SR);
assert_eq(ghurni_is_err(cl), 0, "clock ok");
assert_eq(audio_all_finite(ghurni_clock_synthesize(cl, F64_ONE)), 1, "clock finite");

var ratios = vec_new();
vec_push(ratios, 3.5); vec_push(ratios, 2.1); vec_push(ratios, 1.4); vec_push(ratios, F64_ONE); vec_push(ratios, 0.8);
var tr = ghurni_transmission_new(ratios, 24, SR);
assert_eq(ghurni_is_err(tr), 0, "transmission ok");
ghurni_transmission_shift_to(tr, 2);
assert_eq(audio_all_finite(ghurni_transmission_synthesize(tr, f64_from(3000), HALF)), 1, "transmission finite");

var di = ghurni_differential_new(41, 11, SR);
assert_eq(ghurni_is_err(di), 0, "differential ok");
assert_eq(audio_all_finite(ghurni_differential_synthesize(di, f64_from(2000), HALF)), 1, "differential finite");

var fi = ghurni_forced_induction_new(GH_INDUCTION_TURBO, 2.5, F64_ONE, SR);
assert_eq(ghurni_is_err(fi), 0, "forced induction ok");
assert_eq(audio_all_finite(ghurni_forced_induction_synthesize(fi, f64_from(5000), 0.8, F64_ONE)), 1, "FI finite");

var be = ghurni_belt_drive_new(f64_from(100), 0.7, SR);
assert_eq(ghurni_is_err(be), 0, "belt ok");
assert_eq(audio_all_finite(ghurni_belt_drive_synthesize(be, f64_from(2000), HALF)), 1, "belt finite");

var chn = ghurni_chain_drive_new(110, 15, SR);
assert_eq(ghurni_is_err(chn), 0, "chain ok");
assert_eq(audio_all_finite(ghurni_chain_drive_synthesize(chn, f64_from(3000), HALF)), 1, "chain finite");

# ================================================================
test_group("mixer mono (engine + gear) has energy");
var mix = ghurni_mixer_new();
var me = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, SR);
var mg = ghurni_gear_new(32, GH_GEAR_STEEL, SR);
ghurni_mixer_add_channel(mix, "engine", GH_KIND_ENGINE, me);
ghurni_mixer_add_channel(mix, "gear", GH_KIND_GEAR, mg);
ghurni_mixer_set_rpm(mix, f64_from(3000));
var mout = vec_new();
var mi = 0;
while (mi < 44100) { vec_push(mout, 0); mi = mi + 1; }
ghurni_mixer_process_block(mix, mout);
assert_eq(audio_has_energy(mout), 1, "mixer mono energy");

# ================================================================
test_group("preset v8_muscle_car has energy");
var v8 = ghurni_preset_v8_muscle_car(SR);
assert_eq(ghurni_is_err(v8), 0, "preset ok");
assert_eq(audio_has_energy(ghurni_engine_synthesize(v8, f64_from(3000), 0.6, HALF)), 1, "v8 energy");

var rc = assert_summary();
syscall(60, rc);
