# engine.tcyr -- ports the Engine integration tests from
# rust-old/tests/integration.rs (test_gasoline_engine, test_diesel_engine,
# test_two_stroke, test_all_engine_types, test_firing_frequency,
# test_custom_firing_order, test_engine_events, test_engine_decel_pop,
# test_higher_load_more_energy, test_engine_parameter_sweep,
# test_serde_roundtrip_engine_type). Behavioural parity: valid audio (finite),
# has energy, energy ordering, firing-frequency math, enum serde roundtrip.

include "src/error.cyr"
include "src/logging.cyr"
include "src/dsp.cyr"
include "src/smooth.cyr"
include "src/event.cyr"
include "src/traits.cyr"
include "src/engine.cyr"

# ---- audio assertion helpers (port assert_valid_audio / assert_has_energy) ----
fn audio_all_finite(v) {
    var n = vec_len(v);
    if (n == 0) { return 0; }
    var i = 0;
    while (i < n) {
        if (ghurni_is_finite(vec_get(v, i)) == 0) { return 0; }
        i = i + 1;
    }
    return 1;
}
fn audio_has_energy(v) {
    if (audio_all_finite(v) == 0) { return 0; }
    var n = vec_len(v);
    var i = 0;
    while (i < n) {
        if (f64_gt(f64_abs(vec_get(v, i)), 0.001) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}
fn audio_energy(v) {
    var n = vec_len(v);
    var sum = 0;
    var i = 0;
    while (i < n) {
        var s = vec_get(v, i);
        sum = f64_add(sum, f64_mul(s, s));
        i = i + 1;
    }
    return sum;
}

alloc_init();

# ================================================================
test_group("gasoline / diesel / two-stroke");
var eng = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, f64_from(44100));
assert_eq(ghurni_is_err(eng), 0, "gasoline constructs");
var s1 = ghurni_engine_synthesize(eng, f64_from(3000), 0.5, F64_ONE);
assert_eq(audio_has_energy(s1), 1, "gasoline @3000/0.5 has energy");

var dsl = ghurni_engine_new(GH_ENGINE_DIESEL, 6, f64_from(44100));
var s2 = ghurni_engine_synthesize(dsl, f64_from(2000), 0.7, F64_ONE);
assert_eq(audio_all_finite(s2), 1, "diesel valid audio");

var ts = ghurni_engine_new(GH_ENGINE_TWO_STROKE, 1, f64_from(44100));
var s3 = ghurni_engine_synthesize(ts, f64_from(5000), 0.8, 0.5);
assert_eq(audio_all_finite(s3), 1, "two-stroke valid audio");

# ================================================================
test_group("all engine types construct + synthesize");
var t = 0;
while (t < 4) {
    var e = ghurni_engine_new(t, 4, f64_from(44100));
    assert_eq(ghurni_is_err(e), 0, "type constructs");
    var s = ghurni_engine_synthesize(e, f64_from(2000), 0.5, 0.3);
    assert_eq(audio_all_finite(s), 1, "type valid audio");
    t = t + 1;
}

# ================================================================
test_group("firing frequency (gasoline 4cyl @3000 = 100 Hz)");
var effq = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, f64_from(44100));
var ff = ghurni_engine_firing_frequency(effq, f64_from(3000));
assert_eq(f64_lt(f64_abs(f64_sub(ff, f64_from(100))), 0.01), 1, "ff ~ 100");

# ================================================================
test_group("custom firing order (cross-plane V8)");
var v8 = ghurni_engine_new(GH_ENGINE_GASOLINE, 8, f64_from(44100));
var order = vec_new();
vec_push(order, f64_from(0));   vec_push(order, f64_from(90));
vec_push(order, f64_from(270)); vec_push(order, f64_from(180));
vec_push(order, f64_from(540)); vec_push(order, f64_from(630));
vec_push(order, f64_from(450)); vec_push(order, f64_from(360));
ghurni_engine_set_firing_order(v8, order);
var s8 = ghurni_engine_synthesize(v8, f64_from(3000), 0.6, 0.5);
assert_eq(audio_has_energy(s8), 1, "V8 custom order has energy");

# ================================================================
test_group("events (backfire + misfire + knock)");
var eev = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, f64_from(44100));
ghurni_engine_set_rpm(eev, f64_from(4000));
ghurni_engine_set_load(eev, 0.7);
ghurni_engine_trigger_event(eev, ghurni_event_backfire());
ghurni_engine_trigger_event(eev, ghurni_event_misfire(0));
ghurni_engine_trigger_event(eev, ghurni_event_knock(1));
var evout = vec_new();
var ei = 0;
while (ei < 4410) { vec_push(evout, 0); ei = ei + 1; }
ghurni_engine_process_block(eev, evout);
assert_eq(audio_all_finite(evout), 1, "events valid audio");

# ================================================================
test_group("decel pop (sharp load drop at high RPM)");
var edp = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, f64_from(44100));
ghurni_engine_set_rpm(edp, f64_from(5000));
ghurni_engine_set_load(edp, 0.8);
var warm = vec_new();
var wi = 0;
while (wi < 4410) { vec_push(warm, 0); wi = wi + 1; }
ghurni_engine_process_block(edp, warm);
ghurni_engine_set_load(edp, 0);
var dec = vec_new();
var di = 0;
while (di < 44100) { vec_push(dec, 0); di = di + 1; }
ghurni_engine_process_block(edp, dec);
assert_eq(audio_all_finite(dec), 1, "decel valid audio");

# ================================================================
test_group("higher load => more energy");
var elo = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, f64_from(44100));
var ehi = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, f64_from(44100));
var lo = ghurni_engine_synthesize(elo, f64_from(3000), 0.2, F64_ONE);
var hi = ghurni_engine_synthesize(ehi, f64_from(3000), 0.9, F64_ONE);
assert_eq(f64_gt(audio_energy(hi), audio_energy(lo)), 1, "hi load energy > lo load");

# ================================================================
test_group("parameter sweep -- all finite (no NaN/Inf)");
var rpms = vec_new();
vec_push(rpms, f64_from(100));  vec_push(rpms, f64_from(500));
vec_push(rpms, f64_from(1000)); vec_push(rpms, f64_from(3000));
vec_push(rpms, f64_from(6000)); vec_push(rpms, f64_from(10000));
vec_push(rpms, f64_from(15000));
var loads = vec_new();
vec_push(loads, 0);   vec_push(loads, 0.25); vec_push(loads, 0.5);
vec_push(loads, 0.75); vec_push(loads, F64_ONE);
var swp_ok = 1;
var ri = 0;
while (ri < vec_len(rpms)) {
    var li = 0;
    while (li < vec_len(loads)) {
        var es = ghurni_engine_new(GH_ENGINE_GASOLINE, 4, f64_from(44100));
        var ss = ghurni_engine_synthesize(es, vec_get(rpms, ri), vec_get(loads, li), 0.1);
        if (audio_all_finite(ss) == 0) { swp_ok = 0; }
        li = li + 1;
    }
    ri = ri + 1;
}
assert_eq(swp_ok, 1, "sweep 7x5 all finite");

# ================================================================
test_group("serde roundtrip: EngineType::Diesel");
var nm = ghurni_enginetype_name(GH_ENGINE_DIESEL);
assert_eq(streq(nm, "Diesel"), 1, "name == Diesel");
assert_eq(ghurni_enginetype_from_name(nm), GH_ENGINE_DIESEL, "roundtrips to Diesel");

var rc = assert_summary();
syscall(60, rc);
