# ghurni.cyr -- bundled distribution
# Version: 2.0.0
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- error.cyr ---

# error.cyr -- ghurni error codes + shared f64 constants and base helpers.
# L0 base module: ordered FIRST by every build/test entry. Modules never
# `include` each other -- the entry file / test harness orders them.
#
# Ports rust-old/src/error.rs (the `GhurniError` enum + `Result<T>` alias).
# Rust carried a String payload per variant; the Cyrius port uses integer
# codes -- fallible functions return GH_ERR_NONE (0) on success or a negative
# code on failure; diagnostic text via ghurni_err_name().
#
# NAMING: every ghurni top-level symbol is `ghurni_`/`GHURNI_`/`Gh`-prefixed
# so the ghurni distlib coexists with the naad bundle (which exports
# osc_*/noise_*/filter_biquad_*/additive_*/modulation_lfo_*/db_to_amplitude and
# its own ERR_*/validate_*) in one flat namespace.
#
# FLOATS: ghurni's Rust was f32; the Cyrius port is f64 throughout (naad/hisab
# are f64-only, widening is forced and improves precision). Decimal float
# literals (0.08, 46.05...) lex to f64 bit patterns and feed the f64_* builtins
# directly. GHURNI_EPSILON preserves the f32::EPSILON (2^-23) tolerance the Rust
# tests used, promoted to f64. Test tolerances are loosened vs the f32 oracle
# where bit-exactness is not meaningful.

# ================================================================
# Error codes (was `enum GhurniError`). One per Rust variant, in order.
# ================================================================
var GH_ERR_NONE              = 0;
var GH_ERR_INVALID_PARAMETER = (0 - 1);   # a parameter is out of valid range
var GH_ERR_SYNTHESIS_FAILED  = (0 - 2);   # a synthesis operation failed
var GH_ERR_COMPUTATION       = (0 - 3);   # a computation produced an invalid result

# ================================================================
# Shared f64 sentinels / tolerances (IEEE-754 bit patterns). Exported for
# consumers (clamps, tests). GHURNI_EPSILON = f32::EPSILON promoted.
# ================================================================
var GHURNI_EPSILON = 0x3E80000000000000;   # f32::EPSILON = 2^-23 ~ 1.192e-7
var GHURNI_POS_INF = 0x7FF0000000000000;   # +inf
var GHURNI_NEG_INF = 0xFFF0000000000000;   # -inf

# Shared audio/math constants. TAU / PI / FRAC_PI_2 come from the math stdlib
# (F64_TAU / F64_PI / F64_PI_2). GHURNI_DB_SCALE reproduces the Rust naad path's
# `db_to_amplitude(x * 20.0 / core::f32::consts::LOG10_E)` exactly, factored as
# `db_to_amplitude(x * GHURNI_DB_SCALE)` with GHURNI_DB_SCALE = 20 / LOG10_E.
var GHURNI_DB_SCALE = 46.051701859880914;   # 20.0 / core::f32::consts::LOG10_E

# 1 if `code` is an error (negative), 0 otherwise. A naad constructor that
# fails returns a small negative ERR_* code; a success returns a large positive
# heap pointer -- so this cleanly distinguishes them too.
#must_use
fn ghurni_is_err(code) {
    if (code < 0) { return 1; }
    return 0;
}

# Static name for an error code (diagnostics / logging / serde parity).
#must_use
fn ghurni_err_name(code) {
    if (code == GH_ERR_NONE) { return "none"; }
    if (code == GH_ERR_INVALID_PARAMETER) { return "invalid parameter"; }
    if (code == GH_ERR_SYNTHESIS_FAILED) { return "synthesis failed"; }
    if (code == GH_ERR_COMPUTATION) { return "computation error"; }
    return "unknown error";
}

# Finite test: 1 iff x is neither +/-inf nor NaN. abs(x) < +inf holds for
# finite x, fails for infinities (inf < inf is false) and NaN (any NaN compare
# is false). Mirrors Rust `f32::is_finite`.
#must_use
fn ghurni_is_finite(x) {
    return f64_lt(f64_abs(x), GHURNI_POS_INF);
}

# Floored f64 remainder: a mod b = a - b*floor(a/b). For the non-negative
# operands ghurni uses (crank angle, sample position, tick/engage phase) this
# equals Rust's truncated `%`. Assumes b > 0.
#must_use
fn ghurni_fmod(a, b) {
    return f64_sub(a, f64_mul(b, f64_floor(f64_div(a, b))));
}

# --- logging.cyr ---

# logging.cyr -- structured logging, wired through sakshi.
#
# The Rust crate emitted diagnostics via `tracing` (warn!/error!, gated behind
# the `logging` feature). The Cyrius port wires them for real via sakshi (same
# pattern naad/src/logging and goonj/src/logging use). Logging is always
# compiled in; verbosity is controlled at runtime with sakshi_set_level. These
# thin wrappers take a NUL-terminated cstring and forward (ptr, len) to sakshi.
# They are called for their side effect (not #must_use); each returns 0.
#
# Requires the sakshi bundle (resolved from cyrius.cyml [deps.sakshi]) + strlen
# (stdlib). The module file has no `include` lines.
#
# Mapping from the Rust oracle's tracing calls:
#   dsp.rs  tracing::warn!("invalid sample rate")   -> ghurni_log_warn
#   dsp.rs  tracing::warn!("invalid duration")      -> ghurni_log_warn
#   dsp.rs  tracing::error!("naad backend error")   -> ghurni_log_error

fn ghurni_log_fatal(msg) { sakshi_fatal(msg, strlen(msg)); return 0; }
fn ghurni_log_error(msg) { sakshi_error(msg, strlen(msg)); return 0; }
fn ghurni_log_warn(msg)  { sakshi_warn(msg, strlen(msg));  return 0; }
fn ghurni_log_info(msg)  { sakshi_info(msg, strlen(msg));  return 0; }
fn ghurni_log_debug(msg) { sakshi_debug(msg, strlen(msg)); return 0; }

# --- dsp.cyr ---

# dsp.cyr -- shared DSP primitives for mechanical synthesis.
# Ports rust-old/src/dsp.rs: a one-pole high-pass DC blocker (applied to every
# synth's output), sample-rate / duration validation, and naad error mapping.
# All three were `pub(crate)`.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_finite),
# logging.cyr (ghurni_log_warn/_error) + stdlib alloc/vec + math (F64_ONE/
# F64_TAU, f64_* builtins). The module file itself has no `include` lines.
#
# serde: DcBlocker was Serialize/Deserialize in Rust; RESTORED via
# #derive(Serialize) (f64 fields typed i64 so their exact bit patterns
# serialize losslessly). Roundtrip tested in tests/dsp.tcyr.

# ================================================================
# GhDcBlocker -- one-pole DC blocker. Transfer fn y[n] = x[n] - x[n-1] +
# R*y[n-1]; removes DC offset with a ~10 Hz corner.
#   x_prev : previous input sample
#   y_prev : previous output sample
#   r      : pole radius, clamp(1 - TAU*10/sr, 0.9, 0.9999)
# ================================================================
# Fields TYPED as i64 for #derive(Serialize): each holds an f64 BIT PATTERN, and
# serializing it as an int emits the exact 64-bit value (lossless). Typing as
# f64 would use the derive's decimal float writer (lossy ~1 ULP). Auto-generates
# GhDcBlocker_to_json / _from_json_str -- ports the Rust `#[derive(Serialize,
# Deserialize)]` on DcBlocker.
#derive(accessors)
#derive(Serialize)
struct GhDcBlocker {
    x_prev: i64;
    y_prev: i64;
    r: i64;
}

# new(sample_rate) -- zeroed state; pole radius from the sample rate.
#must_use
fn ghurni_dcblocker_new(sample_rate) {
    var b = alloc(sizeof(GhDcBlocker));
    GhDcBlocker_set_x_prev(b, 0);
    GhDcBlocker_set_y_prev(b, 0);
    # r = clamp(1.0 - (TAU * 10 / sample_rate), 0.9, 0.9999)
    var r = f64_sub(F64_ONE, f64_div(f64_mul(F64_TAU, f64_from(10)), sample_rate));
    GhDcBlocker_set_r(b, f64_clamp(r, 0.9, 0.9999));
    return b;
}

# process(x) -- one sample. y = x - x_prev + r*y_prev; then shift state.
#inline
fn ghurni_dcblocker_process(b, x) {
    var y = f64_add(f64_sub(x, GhDcBlocker_x_prev(b)), f64_mul(GhDcBlocker_r(b), GhDcBlocker_y_prev(b)));
    GhDcBlocker_set_x_prev(b, x);
    GhDcBlocker_set_y_prev(b, y);
    return y;
}

# process_buffer(samples) -- DC-block a vec of f64 samples in place.
fn ghurni_dcblocker_process_buffer(b, samples) {
    var n = vec_len(samples);
    var i = 0;
    while (i < n) {
        vec_set(samples, i, ghurni_dcblocker_process(b, vec_get(samples, i)));
        i = i + 1;
    }
    return 0;
}

# reset() -- clear the filter memory (pole radius preserved).
fn ghurni_dcblocker_reset(b) {
    GhDcBlocker_set_x_prev(b, 0);
    GhDcBlocker_set_y_prev(b, 0);
    return 0;
}

# ================================================================
# Validation. Rust returned Result<()>; the port returns GH_ERR_NONE (0) on
# success or GH_ERR_INVALID_PARAMETER, logging a warning first (ports the
# `#[cfg(feature = "logging")] tracing::warn!` arms).
# ================================================================
#must_use
fn ghurni_validate_sample_rate(sample_rate) {
    if (f64_le(sample_rate, 0) == 1) {
        ghurni_log_warn("ghurni: invalid sample rate (must be positive and finite)");
        return GH_ERR_INVALID_PARAMETER;
    }
    if (ghurni_is_finite(sample_rate) == 0) {
        ghurni_log_warn("ghurni: invalid sample rate (must be positive and finite)");
        return GH_ERR_INVALID_PARAMETER;
    }
    return GH_ERR_NONE;
}

#must_use
fn ghurni_validate_duration(duration) {
    if (f64_le(duration, 0) == 1) {
        ghurni_log_warn("ghurni: invalid duration (must be positive and finite)");
        return GH_ERR_INVALID_PARAMETER;
    }
    if (ghurni_is_finite(duration) == 0) {
        ghurni_log_warn("ghurni: invalid duration (must be positive and finite)");
        return GH_ERR_INVALID_PARAMETER;
    }
    return GH_ERR_NONE;
}

# map_naad_error -- ports naad_init_error (naad-backend gated). Rust emitted a
# `tracing::error!(... "naad backend error")` and returned
# GhurniError::SynthesisFailed; the port wires the diagnostic to sakshi and
# returns GH_ERR_SYNTHESIS_FAILED. Any nonzero (negative) naad code maps here.
#must_use
fn ghurni_map_naad_error(naad_code) {
    ghurni_log_error("ghurni: naad backend synthesis init failed");
    return GH_ERR_SYNTHESIS_FAILED;
}

# --- smooth.cyr ---

# smooth.cyr -- one-pole exponential parameter smoother.
# Ports rust-old/src/smooth.rs (SmoothedParam). Prevents clicks when RPM / load
# change mid-block by exponentially approaching the target. Was a `pub` type.
#
# Requires (from the build/test unit): stdlib alloc + math (F64_ONE, f64_*
# builtins). The module file has no `include` lines.
#
# serde: SmoothedParam was Serialize/Deserialize; RESTORED via #derive(Serialize)
# (f64 fields typed i64 for lossless bit-pattern serialization). Auto-generates
# GhSmoothedParam_to_json / _from_json_str.

# is_settled tolerance: 1e-6 (Rust used the literal 1e-6, not f32::EPSILON).
var GHURNI_SMOOTH_SETTLE = 0.000001;   # 1e-6

# ================================================================
# GhSmoothedParam
#   current : current smoothed value
#   target  : target value (approached smoothly)
#   coeff   : one-pole coefficient exp(-1/(smooth_time_s*sample_rate)), or 0
# ================================================================
#derive(accessors)
#derive(Serialize)
struct GhSmoothedParam {
    current: i64;
    target: i64;
    coeff: i64;
}

# new(initial, smooth_time_s, sample_rate). coeff = exp(-1/(t*sr)) when both
# t>0 and sr>0, else 0 (snaps instantly).
#must_use
fn ghurni_smooth_new(initial, smooth_time_s, sample_rate) {
    var p = alloc(sizeof(GhSmoothedParam));
    var coeff = 0;
    if ((f64_gt(smooth_time_s, 0) == 1) && (f64_gt(sample_rate, 0) == 1)) {
        coeff = f64_exp(f64_neg(f64_div(F64_ONE, f64_mul(smooth_time_s, sample_rate))));
    }
    GhSmoothedParam_set_current(p, initial);
    GhSmoothedParam_set_target(p, initial);
    GhSmoothedParam_set_coeff(p, coeff);
    return p;
}

# set_target(v) -- set the value to smoothly approach.
fn ghurni_smooth_set_target(p, target) {
    GhSmoothedParam_set_target(p, target);
    return 0;
}

# next_value() -- advance one sample: current = target + coeff*(current-target).
#inline
fn ghurni_smooth_next_value(p) {
    var target = GhSmoothedParam_target(p);
    var cur = f64_add(target, f64_mul(GhSmoothedParam_coeff(p), f64_sub(GhSmoothedParam_current(p), target)));
    GhSmoothedParam_set_current(p, cur);
    return cur;
}

# snap() -- jump instantly to target (no smoothing).
fn ghurni_smooth_snap(p) {
    GhSmoothedParam_set_current(p, GhSmoothedParam_target(p));
    return 0;
}

# current() -- read the current smoothed value without advancing.
#must_use
fn ghurni_smooth_current(p) {
    return GhSmoothedParam_current(p);
}

# target() -- read the target value.
#must_use
fn ghurni_smooth_target(p) {
    return GhSmoothedParam_target(p);
}

# is_settled() -- 1 iff |current - target| < 1e-6.
#must_use
fn ghurni_smooth_is_settled(p) {
    var d = f64_abs(f64_sub(GhSmoothedParam_current(p), GhSmoothedParam_target(p)));
    return f64_lt(d, GHURNI_SMOOTH_SETTLE);
}

# --- event.cyr ---

# event.cyr -- discrete mechanical event triggers.
# Ports rust-old/src/event.rs (the `MechanicalEvent` enum). The Rust enum mixed
# nullary variants (Backfire, Stall, RevLimiterHit, Startup, Shutdown) with
# payload variants (Misfire{cylinder}, Knock{cylinder}, GearShift{from,to}).
# The Cyrius port encodes the discriminant as a GH_EVENT_* integer constant and
# carries the (at most two) payload fields in a small GhEvent struct, so one
# representation covers every variant.
#
# Requires (from the build/test unit): stdlib alloc (+ str/bayan for serde).
# The module file has no `include` lines.
#
# serde: MechanicalEvent was Serialize/Deserialize (the GearShift roundtrip is
# exercised in the Rust integration tests); RESTORED via #derive(Serialize) on
# GhEvent -> GhEvent_to_json / _from_json_str, plus a name mapping mirroring
# serde's externally-tagged variant names.

# ================================================================
# Event kinds (was `enum MechanicalEvent`). One per Rust variant, in order.
# ================================================================
var GH_EVENT_BACKFIRE        = 0;   # explosive pop in exhaust
var GH_EVENT_MISFIRE         = 1;   # skipped combustion; payload = cylinder
var GH_EVENT_KNOCK           = 2;   # pre-detonation ping; payload = cylinder
var GH_EVENT_STALL           = 3;   # RPM drops to zero
var GH_EVENT_REV_LIMITER_HIT = 4;   # fuel cut at max RPM
var GH_EVENT_GEAR_SHIFT      = 5;   # payload = from, to
var GH_EVENT_STARTUP         = 6;   # startup sequence
var GH_EVENT_SHUTDOWN        = 7;   # shutdown sequence

# ================================================================
# GhEvent -- discriminant + up to two integer payload fields.
#   kind : GH_EVENT_* constant
#   arg0 : cylinder (Misfire/Knock) or `from` gear (GearShift); else 0
#   arg1 : `to` gear (GearShift); else 0
# ================================================================
#derive(accessors)
#derive(Serialize)
struct GhEvent {
    kind: i64;
    arg0: i64;
    arg1: i64;
}

# General constructor.
#must_use
fn ghurni_event_new(kind, arg0, arg1) {
    var e = alloc(sizeof(GhEvent));
    GhEvent_set_kind(e, kind);
    GhEvent_set_arg0(e, arg0);
    GhEvent_set_arg1(e, arg1);
    return e;
}

# Variant convenience constructors (mirror the Rust variant names).
#must_use
fn ghurni_event_backfire()          { return ghurni_event_new(GH_EVENT_BACKFIRE, 0, 0); }
#must_use
fn ghurni_event_misfire(cylinder)   { return ghurni_event_new(GH_EVENT_MISFIRE, cylinder, 0); }
#must_use
fn ghurni_event_knock(cylinder)     { return ghurni_event_new(GH_EVENT_KNOCK, cylinder, 0); }
#must_use
fn ghurni_event_stall()             { return ghurni_event_new(GH_EVENT_STALL, 0, 0); }
#must_use
fn ghurni_event_rev_limiter_hit()   { return ghurni_event_new(GH_EVENT_REV_LIMITER_HIT, 0, 0); }
#must_use
fn ghurni_event_gear_shift(from, to){ return ghurni_event_new(GH_EVENT_GEAR_SHIFT, from, to); }
#must_use
fn ghurni_event_startup()           { return ghurni_event_new(GH_EVENT_STARTUP, 0, 0); }
#must_use
fn ghurni_event_shutdown()          { return ghurni_event_new(GH_EVENT_SHUTDOWN, 0, 0); }

# Externally-tagged variant name (serde parity / diagnostics).
#must_use
fn ghurni_event_name(kind) {
    if (kind == GH_EVENT_BACKFIRE)        { return "Backfire"; }
    if (kind == GH_EVENT_MISFIRE)         { return "Misfire"; }
    if (kind == GH_EVENT_KNOCK)           { return "Knock"; }
    if (kind == GH_EVENT_STALL)           { return "Stall"; }
    if (kind == GH_EVENT_REV_LIMITER_HIT) { return "RevLimiterHit"; }
    if (kind == GH_EVENT_GEAR_SHIFT)      { return "GearShift"; }
    if (kind == GH_EVENT_STARTUP)         { return "Startup"; }
    if (kind == GH_EVENT_SHUTDOWN)        { return "Shutdown"; }
    return "Unknown";
}

# --- traits.cyr ---

# traits.cyr -- Synthesizer trait replacement: GH_KIND_* dispatch tags.
#
# Rust had `trait Synthesizer { process_block(&mut [f32]); set_rpm(f32);
# rpm() -> f32; sample_rate() -> f32 }` and used `Box<dyn Synthesizer>` trait
# objects (the mixer's channels, and the `test_synthesizer_trait_dispatch`
# heterogeneous vector). Cyrius has no vtables and no dynamic dispatch (ADR-004:
# method dispatch is convention-based `Struct_method`, resolved at compile time;
# trait objects "remain a library pattern, not compiler-native").
#
# The port replaces the trait object with a (kind, pointer) pair: each synth
# instance is tagged with its GH_KIND_* discriminant, and a small dispatcher
# (ghurni_synth_process_block / ghurni_synth_set_rpm, defined in mixer.cyr where
# the heterogeneity actually lives) switches on the tag to call the concrete
# synth's method. These constants are the shared vocabulary between the synth
# modules, the mixer, and consumers building heterogeneous synth collections.
#
# The module has no `include` lines and no internal deps.

var GH_KIND_ENGINE           = 0;
var GH_KIND_GEAR             = 1;
var GH_KIND_MOTOR            = 2;
var GH_KIND_TURBINE          = 3;
var GH_KIND_CLOCK            = 4;
var GH_KIND_TRANSMISSION     = 5;
var GH_KIND_DIFFERENTIAL     = 6;
var GH_KIND_FORCED_INDUCTION = 7;
var GH_KIND_BELT_DRIVE       = 8;
var GH_KIND_CHAIN_DRIVE      = 9;

# --- engine.cyr ---

# engine.cyr -- internal combustion engine synthesis.
# Ports rust-old/src/engine.rs (EngineType enum + Engine synth). Models engines
# as periodic combustion impulses at RPM-dependent rates, shaped by exhaust /
# intake resonance and firing order, with misfire / knock / decel-pop / backfire
# events. This module is the REFERENCE synth -- the other nine follow its shape.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, GHURNI_DB_SCALE,
# ghurni_is_err, ghurni_fmod), logging.cyr, dsp.cyr (GhDcBlocker + validation +
# naad error map), smooth.cyr (GhSmoothedParam), event.cyr (GhEvent + GH_EVENT_*)
# + the naad bundle (noise_*/filter_biquad_*/db_to_amplitude) + stdlib
# alloc/vec/math. No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness), matching how prani/naad were ported.
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - naad constructors return a heap pointer on success or a negative ERR_* code
#   on bad params; ghurni_is_err() distinguishes them. new() maps any failure to
#   GH_ERR_SYNTHESIS_FAILED (ports the Rust `.map_err(SynthesisFailed)`).
# - serde: Engine held opaque naad backend pointers; deep #[derive(Serialize)]
#   is dropped (the integration tests only roundtrip EngineType + GhurniError,
#   which ARE supported -- see ghurni_enginetype_name/_from_name below).

# ================================================================
# EngineType (was `enum EngineType`). One per Rust variant, in order.
# ================================================================
var GH_ENGINE_GASOLINE   = 0;   # 4-stroke gasoline
var GH_ENGINE_DIESEL     = 1;   # 4-stroke diesel
var GH_ENGINE_TWO_STROKE = 2;   # 2-stroke (fires every revolution)
var GH_ENGINE_HYBRID     = 3;   # electric-with-whine

# Externally-tagged serde variant name (parity with serde_json).
#must_use
fn ghurni_enginetype_name(t) {
    if (t == GH_ENGINE_GASOLINE)   { return "Gasoline"; }
    if (t == GH_ENGINE_DIESEL)     { return "Diesel"; }
    if (t == GH_ENGINE_TWO_STROKE) { return "TwoStroke"; }
    if (t == GH_ENGINE_HYBRID)     { return "Hybrid"; }
    return "Unknown";
}
#must_use
fn ghurni_enginetype_from_name(s) {
    if (streq(s, "Gasoline") == 1)  { return GH_ENGINE_GASOLINE; }
    if (streq(s, "Diesel") == 1)    { return GH_ENGINE_DIESEL; }
    if (streq(s, "TwoStroke") == 1) { return GH_ENGINE_TWO_STROKE; }
    if (streq(s, "Hybrid") == 1)    { return GH_ENGINE_HYBRID; }
    return (0 - 1);
}

# ================================================================
# GhEngine. Accessor fields carry a mix of ints, f64 bit patterns, and heap
# pointers (vecs / smoothers / dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   engine_type(int) cylinders(int 1..16) exhaust_resonance(f64 Hz)
#   intake_resonance(f64 Hz) sample_rate(f64) rpm(f64) load(f64) prev_load(f64)
#   sample_position(int) firing_offsets(vec<f64> deg) misfire_flags(vec<int 0/1>)
#   knock_remaining(vec<int samples>) decel_pop_remaining(int)
#   backfire_remaining(int) smooth_rpm/smooth_load(ptr GhSmoothedParam)
#   dc_blocker(ptr GhDcBlocker) noise_gen(ptr naad NoiseGenerator)
#   exhaust_filter/intake_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhEngine {
    engine_type;
    cylinders;
    exhaust_resonance;
    intake_resonance;
    sample_rate;
    rpm;
    load;
    prev_load;
    sample_position;
    firing_offsets;
    misfire_flags;
    knock_remaining;
    decel_pop_remaining;
    backfire_remaining;
    smooth_rpm;
    smooth_load;
    dc_blocker;
    noise_gen;
    exhaust_filter;
    intake_filter;
}

# Even firing offsets (deg) for `cyl` cylinders. 4-stroke = 720deg cycle,
# 2-stroke = 360deg. offsets[i] = i * (cycle/cyl).
#must_use
fn ghurni_engine_compute_even_firing(engine_type, cyl) {
    var cycle = f64_from(720);
    if (engine_type == GH_ENGINE_TWO_STROKE) { cycle = f64_from(360); }
    var spacing = f64_div(cycle, f64_from(cyl));
    var v = vec_new();
    var i = 0;
    while (i < cyl) {
        vec_push(v, f64_mul(f64_from(i), spacing));
        i = i + 1;
    }
    return v;
}

# new(engine_type, cylinders, sample_rate) -> ptr or GH_ERR_*.
#must_use
fn ghurni_engine_new(engine_type, cylinders, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var cyl = cylinders;
    if (cyl < 1) { cyl = 1; }
    if (cyl > 16) { cyl = 16; }
    var cylf = f64_from(cyl);

    var exhaust = f64_from(300);   # Hybrid default
    if (engine_type == GH_ENGINE_GASOLINE)   { exhaust = f64_add(f64_from(150), f64_mul(cylf, f64_from(20))); }
    elif (engine_type == GH_ENGINE_DIESEL)   { exhaust = f64_add(f64_from(80),  f64_mul(cylf, f64_from(15))); }
    elif (engine_type == GH_ENGINE_TWO_STROKE) { exhaust = f64_add(f64_from(200), f64_mul(cylf, f64_from(30))); }

    var intake = f64_from(600);    # Hybrid default
    if (engine_type == GH_ENGINE_GASOLINE)   { intake = f64_add(f64_from(400), f64_mul(cylf, f64_from(30))); }
    elif (engine_type == GH_ENGINE_DIESEL)   { intake = f64_add(f64_from(250), f64_mul(cylf, f64_from(20))); }
    elif (engine_type == GH_ENGINE_TWO_STROKE) { intake = f64_add(f64_from(500), f64_mul(cylf, f64_from(40))); }

    var nyq = f64_mul(sample_rate, 0.49);

    # naad backend: white noise + exhaust/intake band-pass filters.
    var noise = noise_new(NOISE_WHITE, engine_type * 1000 + cyl);
    var exhaust_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, exhaust, 1.5);
    if (ghurni_is_err(exhaust_filter) == 1) { return ghurni_map_naad_error(exhaust_filter); }
    var intake_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_min(intake, nyq), 2.0);
    if (ghurni_is_err(intake_filter) == 1) { return ghurni_map_naad_error(intake_filter); }

    var self = alloc(sizeof(GhEngine));
    GhEngine_set_engine_type(self, engine_type);
    GhEngine_set_cylinders(self, cyl);
    GhEngine_set_exhaust_resonance(self, exhaust);
    GhEngine_set_intake_resonance(self, intake);
    GhEngine_set_sample_rate(self, sample_rate);
    GhEngine_set_rpm(self, f64_from(800));
    GhEngine_set_load(self, 0);
    GhEngine_set_prev_load(self, 0);
    GhEngine_set_sample_position(self, 0);
    GhEngine_set_firing_offsets(self, ghurni_engine_compute_even_firing(engine_type, cyl));

    var misfire = vec_new();
    var knock = vec_new();
    var i = 0;
    while (i < cyl) { vec_push(misfire, 0); vec_push(knock, 0); i = i + 1; }
    GhEngine_set_misfire_flags(self, misfire);
    GhEngine_set_knock_remaining(self, knock);

    GhEngine_set_decel_pop_remaining(self, 0);
    GhEngine_set_backfire_remaining(self, 0);
    GhEngine_set_smooth_rpm(self, ghurni_smooth_new(f64_from(800), 0.05, sample_rate));
    GhEngine_set_smooth_load(self, ghurni_smooth_new(0, 0.02, sample_rate));
    GhEngine_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhEngine_set_noise_gen(self, noise);
    GhEngine_set_exhaust_filter(self, exhaust_filter);
    GhEngine_set_intake_filter(self, intake_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 100..15000, retarget the smoother.
fn ghurni_engine_set_rpm(self, rpm) {
    var r = f64_clamp(rpm, f64_from(100), f64_from(15000));
    GhEngine_set_rpm(self, r);
    ghurni_smooth_set_target(GhEngine_smooth_rpm(self), r);
    return 0;
}

# set_load(load) -- clamp to 0..1, retarget the smoother, detect decel pop.
fn ghurni_engine_set_load(self, load) {
    GhEngine_set_prev_load(self, GhEngine_load(self));
    var l = f64_clamp(load, 0, F64_ONE);
    GhEngine_set_load(self, l);
    ghurni_smooth_set_target(GhEngine_smooth_load(self), l);
    if ((f64_gt(GhEngine_prev_load(self), 0.5) == 1) && (f64_lt(l, 0.15) == 1) && (f64_gt(GhEngine_rpm(self), f64_from(3000)) == 1)) {
        GhEngine_set_decel_pop_remaining(self, f64_to(f64_mul(GhEngine_sample_rate(self), 0.3)));
    }
    return 0;
}

# set_firing_order(offsets) -- replace the firing order if the length matches.
fn ghurni_engine_set_firing_order(self, offsets) {
    if (vec_len(offsets) == GhEngine_cylinders(self)) {
        GhEngine_set_firing_offsets(self, offsets);
    }
    return 0;
}

# trigger_event(event) -- schedule a mechanical event (GhEvent from event.cyr).
fn ghurni_engine_trigger_event(self, event) {
    var kind = GhEvent_kind(event);
    if (kind == GH_EVENT_BACKFIRE) {
        GhEngine_set_backfire_remaining(self, f64_to(f64_mul(GhEngine_sample_rate(self), 0.1)));
    } elif (kind == GH_EVENT_MISFIRE) {
        var cyl = GhEvent_arg0(event);
        var flags = GhEngine_misfire_flags(self);
        if ((cyl >= 0) && (cyl < vec_len(flags))) { vec_set(flags, cyl, 1); }
    } elif (kind == GH_EVENT_KNOCK) {
        var cyl2 = GhEvent_arg0(event);
        var kr = GhEngine_knock_remaining(self);
        if ((cyl2 >= 0) && (cyl2 < vec_len(kr))) {
            vec_set(kr, cyl2, f64_to(f64_mul(GhEngine_sample_rate(self), 0.02)));
        }
    }
    return 0;
}

# firing_frequency(rpm). 4-stroke: revs/sec * cyl / 2. 2-stroke: revs/sec * cyl.
#must_use
fn ghurni_engine_firing_frequency(self, rpm) {
    var revs = f64_div(rpm, f64_from(60));
    var cylf = f64_from(GhEngine_cylinders(self));
    if (GhEngine_engine_type(self) == GH_ENGINE_TWO_STROKE) {
        return f64_mul(revs, cylf);
    }
    return f64_div(f64_mul(revs, cylf), f64_from(2));
}

# roughness_for_load(load). base by type, scaled 0.7 + 0.3*load.
#inline
fn ghurni_engine_roughness_for_load(self, load) {
    var et = GhEngine_engine_type(self);
    var base = 0.05;   # Hybrid
    if (et == GH_ENGINE_DIESEL)        { base = 0.4; }
    elif (et == GH_ENGINE_TWO_STROKE)  { base = 0.3; }
    elif (et == GH_ENGINE_GASOLINE)    { base = 0.15; }
    return f64_mul(base, f64_add(0.7, f64_mul(0.3, load)));
}

# synthesize(rpm, load, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_engine_synthesize(self, rpm, load, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_engine_set_rpm(self, rpm);
    ghurni_engine_set_load(self, load);
    var n = f64_to(f64_mul(GhEngine_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_engine_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with engine sound, DC-block, and
# advance the sample counter.
fn ghurni_engine_process_block(self, out) {
    ghurni_engine_process_block_naad(self, out);
    var db = GhEngine_dc_blocker(self);
    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        vec_set(out, i, ghurni_dcblocker_process(db, vec_get(out, i)));
        i = i + 1;
    }
    GhEngine_set_sample_position(self, GhEngine_sample_position(self) + n);
    return 0;
}

# The naad synthesis core (ports process_block_naad).
fn ghurni_engine_process_block_naad(self, out) {
    var exhaust_filter = GhEngine_exhaust_filter(self);
    filter_biquad_set_params(exhaust_filter, GhEngine_exhaust_resonance(self), 1.5, 0);

    var cycle = f64_from(720);
    if (GhEngine_engine_type(self) == GH_ENGINE_TWO_STROKE) { cycle = f64_from(360); }

    var sr = GhEngine_sample_rate(self);
    var noise = GhEngine_noise_gen(self);
    var intake_filter = GhEngine_intake_filter(self);
    var smooth_rpm = GhEngine_smooth_rpm(self);
    var smooth_load = GhEngine_smooth_load(self);
    var firing = GhEngine_firing_offsets(self);
    var misfire = GhEngine_misfire_flags(self);
    var knock = GhEngine_knock_remaining(self);
    var base_pos = GhEngine_sample_position(self);
    var num_cyl = vec_len(firing);

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var rpm = ghurni_smooth_next_value(smooth_rpm);
        var load = ghurni_smooth_next_value(smooth_load);
        var abs_pos = f64_from(base_pos + i);

        var roughness = ghurni_engine_roughness_for_load(self, load);
        var base_amp = f64_add(0.2, f64_mul(load, 0.5));

        var revs_per_sample = f64_div(rpm, f64_mul(f64_from(60), sr));
        var crank_deg = ghurni_fmod(f64_mul(f64_mul(abs_pos, revs_per_sample), f64_from(360)), cycle);

        # sum combustion impulses from each cylinder
        var combustion_sum = 0;
        var c = 0;
        while (c < num_cyl) {
            var offset = vec_get(firing, c);
            var cyl_phase = ghurni_fmod(f64_sub(crank_deg, offset), cycle);
            var cyl_norm = f64_div(cyl_phase, cycle);

            var skip = 0;
            if ((vec_get(misfire, c) == 1) && (f64_lt(cyl_norm, 0.01) == 1)) {
                vec_set(misfire, c, 0);
                skip = 1;
            }
            if (skip == 0) {
                if (f64_lt(cyl_norm, 0.08) == 1) {
                    var t = f64_div(cyl_norm, 0.08);
                    var pulse = db_to_amplitude(f64_mul(f64_neg(f64_mul(f64_from(8), t)), GHURNI_DB_SCALE));
                    var ns = noise_next_sample(noise);
                    combustion_sum = f64_add(combustion_sum, f64_mul(f64_mul(pulse, base_amp), f64_add(F64_ONE, f64_mul(roughness, ns))));
                }
            }
            c = c + 1;
        }

        # knock: high-frequency metallic ping, per cylinder
        var knock_sum = 0;
        var k = 0;
        while (k < num_cyl) {
            var rem = vec_get(knock, k);
            if (rem > 0) {
                rem = rem - 1;
                vec_set(knock, k, rem);
                var env = f64_div(f64_from(rem), f64_mul(sr, 0.02));
                knock_sum = f64_add(knock_sum, f64_mul(f64_mul(noise_next_sample(noise), env), 0.2));
            }
            k = k + 1;
        }

        # exhaust resonance
        var exhaust_noise = f64_mul(f64_mul(noise_next_sample(noise), base_amp), 0.3);
        var exhaust = f64_mul(filter_biquad_process_sample(exhaust_filter, exhaust_noise), f64_add(0.5, f64_mul(load, 0.5)));

        # intake resonance (louder at higher load)
        var intake_noise = f64_mul(f64_mul(f64_mul(noise_next_sample(noise), base_amp), 0.2), load);
        var intake = filter_biquad_process_sample(intake_filter, intake_noise);

        # decel crackle/pop -- sparse impulses
        var decel = 0;
        var dpr = GhEngine_decel_pop_remaining(self);
        if (dpr > 0) {
            dpr = dpr - 1;
            GhEngine_set_decel_pop_remaining(self, dpr);
            var denv = f64_div(f64_from(dpr), f64_mul(sr, 0.3));
            if (f64_gt(noise_next_sample(noise), 0.95) == 1) {
                decel = f64_mul(f64_mul(noise_next_sample(noise), denv), 0.4);
            }
        }

        # backfire
        var backfire = 0;
        var bpr = GhEngine_backfire_remaining(self);
        if (bpr > 0) {
            bpr = bpr - 1;
            GhEngine_set_backfire_remaining(self, bpr);
            var benv = f64_div(f64_from(bpr), f64_mul(sr, 0.1));
            backfire = f64_mul(f64_mul(noise_next_sample(noise), benv), 0.8);
        }

        # mechanical noise
        var mech = f64_mul(f64_mul(f64_mul(noise_next_sample(noise), roughness), base_amp), 0.1);

        var s = f64_add(combustion_sum, f64_add(exhaust, f64_add(intake, f64_add(mech, f64_add(knock_sum, f64_add(decel, backfire))))));
        vec_set(out, i, s);
        i = i + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_engine_rpm(self) { return GhEngine_rpm(self); }
#must_use
fn ghurni_engine_sample_rate(self) { return GhEngine_sample_rate(self); }

# --- gear.cyr ---

# gear.cyr -- gear mesh sound synthesis.
# Ports rust-old/src/gear.rs (GearMaterial enum + Gear synth). Models the sound
# of meshing gear teeth: a tooth-mesh tone (teeth x RPM), a material-dependent
# metallic resonance ring, and load-dependent broadband noise. Follows the shape
# of the reference synth engine.cyr.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, GHURNI_DB_SCALE,
# ghurni_is_err, ghurni_fmod), logging.cyr, dsp.cyr (GhDcBlocker + validation +
# naad error map) + the naad bundle (osc_*/noise_*/filter_biquad_*/
# db_to_amplitude) + stdlib alloc/vec/math. No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness), matching engine.cyr.
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - naad constructors return a heap pointer on success or a negative ERR_* code
#   on bad params; ghurni_is_err() distinguishes them. new() maps any failure to
#   GH_ERR_SYNTHESIS_FAILED (ports the Rust `.map_err(SynthesisFailed)`).
#   noise_new never errors, so its result is used unchecked (parity with Rust).
# - serde: Gear held opaque naad backend pointers; deep #[derive(Serialize)] is
#   dropped. Serde parity is only for GearMaterial via the name<->code helpers
#   below (the roundtrip test uses Brass).
# - GearMaterial::properties() (resonance_hz, decay_s, brightness) is inlined
#   into new() as three per-variant assignments.

# ================================================================
# GearMaterial (was `enum GearMaterial`). One per Rust variant, in order.
# ================================================================
var GH_GEAR_STEEL     = 0;   # hardened steel -- bright, long ring
var GH_GEAR_CAST_IRON = 1;   # cast iron -- duller, shorter decay
var GH_GEAR_BRASS     = 2;   # brass -- warm, medium ring
var GH_GEAR_NYLON     = 3;   # nylon/plastic -- very dull, short decay

# Externally-tagged serde variant name (parity with serde_json).
#must_use
fn ghurni_gearmaterial_name(t) {
    if (t == GH_GEAR_STEEL)     { return "Steel"; }
    if (t == GH_GEAR_CAST_IRON) { return "CastIron"; }
    if (t == GH_GEAR_BRASS)     { return "Brass"; }
    if (t == GH_GEAR_NYLON)     { return "Nylon"; }
    return "Unknown";
}
#must_use
fn ghurni_gearmaterial_from_name(s) {
    if (streq(s, "Steel") == 1)    { return GH_GEAR_STEEL; }
    if (streq(s, "CastIron") == 1) { return GH_GEAR_CAST_IRON; }
    if (streq(s, "Brass") == 1)    { return GH_GEAR_BRASS; }
    if (streq(s, "Nylon") == 1)    { return GH_GEAR_NYLON; }
    return (0 - 1);
}

# ================================================================
# GhGear. Accessor fields carry a mix of ints, f64 bit patterns, and heap
# pointers (dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   teeth(int 4+) material(int GH_GEAR_*) resonance(f64 Hz) decay(f64 s)
#   brightness(f64) sample_rate(f64) rpm(f64) sample_position(int)
#   dc_blocker(ptr GhDcBlocker) mesh_osc(ptr naad Oscillator)
#   noise_gen(ptr naad NoiseGenerator) resonance_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhGear {
    teeth;
    material;
    resonance;
    decay;
    brightness;
    sample_rate;
    rpm;
    sample_position;
    dc_blocker;
    mesh_osc;
    noise_gen;
    resonance_filter;
}

# new(teeth, material, sample_rate) -> ptr or GH_ERR_*.
#must_use
fn ghurni_gear_new(teeth, material, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var t = teeth;
    if (t < 4) { t = 4; }

    # material.properties() -> (resonance_hz, decay_s, brightness). Nylon default.
    var resonance = f64_from(1000);
    var decay = 0.01;
    var brightness = 0.2;
    if (material == GH_GEAR_STEEL) {
        resonance = f64_from(3500); decay = 0.08; brightness = 0.9;
    } elif (material == GH_GEAR_CAST_IRON) {
        resonance = f64_from(2000); decay = 0.04; brightness = 0.5;
    } elif (material == GH_GEAR_BRASS) {
        resonance = f64_from(2800); decay = 0.06; brightness = 0.7;
    }

    var nyq = f64_mul(sample_rate, 0.49);
    var initial_mesh_freq = f64_min(f64_from(100), nyq);

    # naad backend: sine mesh oscillator + white noise + band-pass resonance.
    var mesh_osc = osc_new(WAVEFORM_SINE, initial_mesh_freq, sample_rate);
    if (ghurni_is_err(mesh_osc) == 1) { return ghurni_map_naad_error(mesh_osc); }
    var noise = noise_new(NOISE_WHITE, t * 7 + material);
    var resonance_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_min(resonance, nyq), 4.0);
    if (ghurni_is_err(resonance_filter) == 1) { return ghurni_map_naad_error(resonance_filter); }

    var self = alloc(sizeof(GhGear));
    GhGear_set_teeth(self, t);
    GhGear_set_material(self, material);
    GhGear_set_resonance(self, resonance);
    GhGear_set_decay(self, decay);
    GhGear_set_brightness(self, brightness);
    GhGear_set_sample_rate(self, sample_rate);
    GhGear_set_rpm(self, f64_from(1000));
    GhGear_set_sample_position(self, 0);
    GhGear_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhGear_set_mesh_osc(self, mesh_osc);
    GhGear_set_noise_gen(self, noise);
    GhGear_set_resonance_filter(self, resonance_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 1..50000.
fn ghurni_gear_set_rpm(self, rpm) {
    var r = f64_clamp(rpm, F64_ONE, f64_from(50000));
    GhGear_set_rpm(self, r);
    return 0;
}

# mesh_frequency(rpm) -- tooth mesh frequency = (rpm/60) * teeth.
#must_use
#inline
fn ghurni_gear_mesh_frequency(self, rpm) {
    return f64_mul(f64_div(rpm, f64_from(60)), f64_from(GhGear_teeth(self)));
}

# synthesize(rpm, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_gear_synthesize(self, rpm, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_gear_set_rpm(self, rpm);
    var n = f64_to(f64_mul(GhGear_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_gear_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with gear mesh sound, DC-block,
# and advance the sample counter.
fn ghurni_gear_process_block(self, out) {
    ghurni_gear_process_block_naad(self, out);
    var db = GhGear_dc_blocker(self);
    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        vec_set(out, i, ghurni_dcblocker_process(db, vec_get(out, i)));
        i = i + 1;
    }
    GhGear_set_sample_position(self, GhGear_sample_position(self) + n);
    return 0;
}

# The naad synthesis core (ports process_block_naad). mesh tone + resonant ring
# excited by a per-mesh-cycle decaying envelope + broadband noise.
fn ghurni_gear_process_block_naad(self, out) {
    var mesh_freq = ghurni_gear_mesh_frequency(self, GhGear_rpm(self));
    var sr = GhGear_sample_rate(self);
    var nyq = f64_mul(sr, 0.49);

    var mesh_osc = GhGear_mesh_osc(self);
    osc_set_frequency(mesh_osc, f64_min(mesh_freq, nyq));

    var noise = GhGear_noise_gen(self);
    var resonance_filter = GhGear_resonance_filter(self);
    var decay = GhGear_decay(self);
    var brightness = GhGear_brightness(self);
    var base_pos = GhGear_sample_position(self);
    var amp = 0.3;

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var mesh = f64_mul(f64_mul(osc_next_sample(mesh_osc), amp), 0.5);

        var abs_pos = f64_from(base_pos + i);
        var mesh_phase = ghurni_fmod(f64_div(f64_mul(abs_pos, mesh_freq), sr), F64_ONE);
        var ring_env = F64_ONE;
        if (f64_lt(mesh_phase, 0.05) == 0) {
            ring_env = db_to_amplitude(f64_mul(f64_div(f64_neg(mesh_phase), decay), GHURNI_DB_SCALE));
        }
        var ring_excitation = f64_mul(noise_next_sample(noise), ring_env);
        var ring = f64_mul(f64_mul(filter_biquad_process_sample(resonance_filter, ring_excitation), amp), brightness);

        var noise_s = f64_mul(f64_mul(noise_next_sample(noise), amp), 0.05);

        vec_set(out, i, f64_add(mesh, f64_add(ring, noise_s)));
        i = i + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_gear_rpm(self) { return GhGear_rpm(self); }
#must_use
fn ghurni_gear_sample_rate(self) { return GhGear_sample_rate(self); }

# --- motor.cyr ---

# motor.cyr -- electric motor sound synthesis.
# Ports rust-old/src/motor.rs (MotorType enum + Motor synth). Models
# electromagnetic hum, commutator/bearing noise, and whine at RPM-dependent
# frequencies. The hum is an additive synth (fundamental + 2nd/3rd partials)
# driven at the electromagnetic frequency; the noise is white noise through a
# band-pass filter. Follows the shape of the reference synth, src/engine.cyr.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_err),
# logging.cyr, dsp.cyr (GhDcBlocker + validation + naad error map) + the naad
# bundle (additive_*/noise_*/filter_biquad_*) + stdlib alloc/vec/math + string
# (streq for the enum name helpers). No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness), matching how engine/prani/naad were ported.
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - naad constructors return a heap pointer on success or a negative ERR_* code
#   on bad params; ghurni_is_err() distinguishes them. new() maps any failure to
#   GH_ERR_SYNTHESIS_FAILED (ports the Rust `.map_err(SynthesisFailed)`).
#   noise_new never errors, so its return is not checked.
# - process_block sets the hum fundamental to min(em_freq, nyquist/3); the
#   Rust ignored additive.set_fundamental's Result (`let _ = ...`), and so do
#   we -- at rpm=0 em_freq is 0 (or the min may go negative), which is fine.
# - serde: Motor held opaque naad backend pointers; deep #[derive(Serialize)]
#   is dropped (only MotorType roundtrips, via ghurni_motortype_name/_from_name
#   below).

# ================================================================
# MotorType (was `enum MotorType`). One per Rust variant, in order.
# ================================================================
var GH_MOTOR_DC_BRUSHED  = 0;   # DC brushed -- commutator noise, medium hum
var GH_MOTOR_AC_INDUCTION = 1;  # AC induction -- smooth 50/60Hz hum base
var GH_MOTOR_BRUSHLESS   = 2;   # brushless DC (BLDC) -- smooth, HF whine
var GH_MOTOR_SERVO       = 3;   # servo -- precise, whiny, variable speed

# Externally-tagged serde variant name (parity with serde_json).
#must_use
fn ghurni_motortype_name(t) {
    if (t == GH_MOTOR_DC_BRUSHED)  { return "DcBrushed"; }
    if (t == GH_MOTOR_AC_INDUCTION) { return "AcInduction"; }
    if (t == GH_MOTOR_BRUSHLESS)   { return "Brushless"; }
    if (t == GH_MOTOR_SERVO)       { return "Servo"; }
    return "Unknown";
}
#must_use
fn ghurni_motortype_from_name(s) {
    if (streq(s, "DcBrushed") == 1)   { return GH_MOTOR_DC_BRUSHED; }
    if (streq(s, "AcInduction") == 1) { return GH_MOTOR_AC_INDUCTION; }
    if (streq(s, "Brushless") == 1)   { return GH_MOTOR_BRUSHLESS; }
    if (streq(s, "Servo") == 1)       { return GH_MOTOR_SERVO; }
    return (0 - 1);
}

# ================================================================
# GhMotor. Accessor fields carry a mix of ints, f64 bit patterns, and heap
# pointers (dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   motor_type(int) poles(int 2..24) sample_rate(f64) rpm(f64) load(f64)
#   sample_position(int) dc_blocker(ptr GhDcBlocker)
#   hum_synth(ptr naad AdditiveSynth) noise_gen(ptr naad NoiseGenerator)
#   noise_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhMotor {
    motor_type;
    poles;
    sample_rate;
    rpm;
    load;
    sample_position;
    dc_blocker;
    hum_synth;
    noise_gen;
    noise_filter;
}

# noise_cutoff (Hz) for the band-pass filter, by motor type.
#must_use
fn ghurni_motor_noise_cutoff(motor_type) {
    if (motor_type == GH_MOTOR_DC_BRUSHED)  { return f64_from(4000); }
    if (motor_type == GH_MOTOR_AC_INDUCTION) { return f64_from(2000); }
    if (motor_type == GH_MOTOR_BRUSHLESS)   { return f64_from(6000); }
    if (motor_type == GH_MOTOR_SERVO)       { return f64_from(3000); }
    return f64_from(3000);
}

# per-type mechanical noise level (commutator / bearing hiss).
#must_use
fn ghurni_motor_noise_level(motor_type) {
    if (motor_type == GH_MOTOR_DC_BRUSHED)  { return 0.15; }
    if (motor_type == GH_MOTOR_AC_INDUCTION) { return 0.05; }
    if (motor_type == GH_MOTOR_BRUSHLESS)   { return 0.02; }
    if (motor_type == GH_MOTOR_SERVO)       { return 0.08; }
    return 0.08;
}

# new(motor_type, poles, sample_rate) -> ptr or GH_ERR_*.
#must_use
fn ghurni_motor_new(motor_type, poles, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var p = poles;
    if (p < 2) { p = 2; }
    if (p > 24) { p = 24; }

    var noise_cutoff = ghurni_motor_noise_cutoff(motor_type);
    var nyq = f64_mul(sample_rate, 0.49);

    # naad backend: additive hum synth (fundamental + 2nd/3rd partials),
    # white noise, and a band-pass filter for the commutator/bearing hiss.
    var hum_synth = additive_new(f64_from(100), 3, sample_rate);
    if (ghurni_is_err(hum_synth) == 1) { return ghurni_map_naad_error(hum_synth); }
    additive_set_partial(hum_synth, 0, F64_ONE, F64_ONE);
    additive_set_partial(hum_synth, 1, f64_from(2), 0.3);
    additive_set_partial(hum_synth, 2, f64_from(3), 0.1);

    var noise = noise_new(NOISE_WHITE, motor_type * 100 + p);
    var noise_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_min(noise_cutoff, nyq), F64_ONE);
    if (ghurni_is_err(noise_filter) == 1) { return ghurni_map_naad_error(noise_filter); }

    var self = alloc(sizeof(GhMotor));
    GhMotor_set_motor_type(self, motor_type);
    GhMotor_set_poles(self, p);
    GhMotor_set_sample_rate(self, sample_rate);
    GhMotor_set_rpm(self, 0);
    GhMotor_set_load(self, 0);
    GhMotor_set_sample_position(self, 0);
    GhMotor_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhMotor_set_hum_synth(self, hum_synth);
    GhMotor_set_noise_gen(self, noise);
    GhMotor_set_noise_filter(self, noise_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 0..100000.
fn ghurni_motor_set_rpm(self, rpm) {
    GhMotor_set_rpm(self, f64_clamp(rpm, 0, f64_from(100000)));
    return 0;
}

# set_load(load) -- clamp to 0..1.
fn ghurni_motor_set_load(self, load) {
    GhMotor_set_load(self, f64_clamp(load, 0, F64_ONE));
    return 0;
}

# electromagnetic hum frequency (Hz) = (rpm / 60) * poles.
#must_use
fn ghurni_motor_em_frequency(self, rpm) {
    return f64_mul(f64_div(rpm, f64_from(60)), f64_from(GhMotor_poles(self)));
}

# synthesize(rpm, load, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_motor_synthesize(self, rpm, load, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_motor_set_rpm(self, rpm);
    ghurni_motor_set_load(self, load);
    var n = f64_to(f64_mul(GhMotor_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_motor_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with motor sound, DC-block, and
# advance the sample counter.
fn ghurni_motor_process_block(self, out) {
    ghurni_motor_process_block_naad(self, out);
    var db = GhMotor_dc_blocker(self);
    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        vec_set(out, i, ghurni_dcblocker_process(db, vec_get(out, i)));
        i = i + 1;
    }
    GhMotor_set_sample_position(self, GhMotor_sample_position(self) + n);
    return 0;
}

# The naad synthesis core (ports process_block_naad).
fn ghurni_motor_process_block_naad(self, out) {
    var hum_synth = GhMotor_hum_synth(self);
    var noise = GhMotor_noise_gen(self);
    var noise_filter = GhMotor_noise_filter(self);

    var em_freq = ghurni_motor_em_frequency(self, GhMotor_rpm(self));
    var nyquist = f64_mul(GhMotor_sample_rate(self), 0.49);
    additive_set_fundamental(hum_synth, f64_min(em_freq, f64_div(nyquist, f64_from(3))));

    var amp = f64_add(0.15, f64_mul(GhMotor_load(self), 0.2));
    var noise_level = ghurni_motor_noise_level(GhMotor_motor_type(self));

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var hum = f64_mul(additive_next_sample(hum_synth), amp);
        var raw_noise = f64_mul(f64_mul(noise_next_sample(noise), noise_level), amp);
        var flt = filter_biquad_process_sample(noise_filter, raw_noise);
        vec_set(out, i, f64_add(hum, flt));
        i = i + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_motor_rpm(self) { return GhMotor_rpm(self); }
#must_use
fn ghurni_motor_sample_rate(self) { return GhMotor_sample_rate(self); }

# --- turbine.cyr ---

# turbine.cyr -- turbine and fan sound synthesis.
# Ports rust-old/src/turbine.rs (Turbine synth). Models blade pass frequency,
# whoosh, and tonal whine for turbines, fans, propellers, and jet engines.
# Kind tag: GH_KIND_TURBINE (dispatch lives in mixer.cyr; see traits.cyr).
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_err),
# logging.cyr, dsp.cyr (GhDcBlocker + validation + naad error map) + the naad
# bundle (additive_*/osc_*/noise_*/modulation_lfo_*) + stdlib alloc/vec/math.
# No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness), matching engine.cyr.
# - There is NO enum for this module (Turbine has no serde-roundtrip enum).
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - naad constructors return a heap pointer on success or a negative ERR_* code
#   on bad params; ghurni_is_err() distinguishes them. new() maps any failure to
#   GH_ERR_SYNTHESIS_FAILED (ports the Rust `.map_err(SynthesisFailed)`).
# - duct_osc is Option<Oscillator> in Rust: built ONLY when duct_resonance > 0,
#   else None. The port stores 0 in the duct_osc field for the None case and
#   guards every use with `if (duct_osc != 0)`.

# ================================================================
# GhTurbine. Accessor fields carry ints, f64 bit patterns, and heap pointers
# (dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   blades(int 2..64) duct_resonance(f64 Hz) sample_rate(f64) rpm(f64)
#   sample_position(int) dc_blocker(ptr GhDcBlocker)
#   blade_synth(ptr naad AdditiveSynth) duct_osc(ptr naad Oscillator, 0 if none)
#   noise_gen(ptr naad NoiseGenerator) whoosh_lfo(ptr naad Lfo)
# ================================================================
#derive(accessors)
struct GhTurbine {
    blades;
    duct_resonance;
    sample_rate;
    rpm;
    sample_position;
    dc_blocker;
    blade_synth;
    duct_osc;
    noise_gen;
    whoosh_lfo;
}

# new(blades, duct_resonance, sample_rate) -> ptr or GH_ERR_*.
# - blades: number of blades/vanes (clamped 2..64).
# - duct_resonance: duct resonant frequency in Hz (max 0.0; 0 = open propeller).
# - sample_rate: audio sample rate in Hz.
#must_use
fn ghurni_turbine_new(blades, duct_resonance, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var b = blades;
    if (b < 2) { b = 2; }
    if (b > 64) { b = 64; }

    var duct = f64_max(duct_resonance, 0);
    var nyquist = f64_mul(sample_rate, 0.49);

    # blade_synth: 2-partial additive synth (fundamental 100 Hz, 2 partials).
    var blade_synth = additive_new(f64_from(100), 2, sample_rate);
    if (ghurni_is_err(blade_synth) == 1) { return ghurni_map_naad_error(blade_synth); }
    additive_set_partial(blade_synth, 0, F64_ONE, F64_ONE);
    additive_set_partial(blade_synth, 1, F64_TWO, 0.4);

    # duct_osc: only when duct_resonance > 0, else store 0 (Rust None).
    var duct_osc = 0;
    if (f64_gt(duct, 0) == 1) {
        duct_osc = osc_new(WAVEFORM_SINE, f64_min(duct, nyquist), sample_rate);
        if (ghurni_is_err(duct_osc) == 1) { return ghurni_map_naad_error(duct_osc); }
    }

    var initial_lfo_rate = f64_min(f64_from(10), nyquist);

    # whoosh_lfo: sine LFO seeded with the initial whoosh rate.
    var whoosh_lfo = modulation_lfo_new(MODULATION_LFO_SINE, initial_lfo_rate, sample_rate);
    if (ghurni_is_err(whoosh_lfo) == 1) { return ghurni_map_naad_error(whoosh_lfo); }

    # noise_gen: pink noise (never errors). Seed derives from blades + duct.
    var noise = noise_new(NOISE_PINK, b * 13 + f64_to(duct));

    var self = alloc(sizeof(GhTurbine));
    GhTurbine_set_blades(self, b);
    GhTurbine_set_duct_resonance(self, duct);
    GhTurbine_set_sample_rate(self, sample_rate);
    GhTurbine_set_rpm(self, f64_from(1000));
    GhTurbine_set_sample_position(self, 0);
    GhTurbine_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhTurbine_set_blade_synth(self, blade_synth);
    GhTurbine_set_duct_osc(self, duct_osc);
    GhTurbine_set_noise_gen(self, noise);
    GhTurbine_set_whoosh_lfo(self, whoosh_lfo);
    return self;
}

# set_rpm(rpm) -- clamp to 1..200000.
fn ghurni_turbine_set_rpm(self, rpm) {
    var r = f64_clamp(rpm, F64_ONE, f64_from(200000));
    GhTurbine_set_rpm(self, r);
    return 0;
}

# blade_pass_frequency(rpm) = (rpm / 60) * blades.
#must_use
#inline
fn ghurni_turbine_blade_pass_frequency(self, rpm) {
    return f64_mul(f64_div(rpm, f64_from(60)), f64_from(GhTurbine_blades(self)));
}

# synthesize(rpm, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_turbine_synthesize(self, rpm, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_turbine_set_rpm(self, rpm);
    var n = f64_to(f64_mul(GhTurbine_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_turbine_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with turbine sound, DC-block, and
# advance the sample counter.
fn ghurni_turbine_process_block(self, out) {
    ghurni_turbine_process_block_naad(self, out);
    var db = GhTurbine_dc_blocker(self);
    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        vec_set(out, i, ghurni_dcblocker_process(db, vec_get(out, i)));
        i = i + 1;
    }
    GhTurbine_set_sample_position(self, GhTurbine_sample_position(self) + n);
    return 0;
}

# The naad synthesis core (ports process_block_naad).
fn ghurni_turbine_process_block_naad(self, out) {
    var bpf = ghurni_turbine_blade_pass_frequency(self, GhTurbine_rpm(self));
    var nyquist = f64_mul(GhTurbine_sample_rate(self), 0.49);
    var amp = 0.3;

    var blade_synth = GhTurbine_blade_synth(self);
    var whoosh_lfo = GhTurbine_whoosh_lfo(self);
    var noise = GhTurbine_noise_gen(self);
    var duct_osc = GhTurbine_duct_osc(self);

    additive_set_fundamental(blade_synth, f64_min(bpf, f64_div(nyquist, f64_from(2))));
    var lfo_freq = f64_clamp(bpf, 0.01, nyquist);
    modulation_lfo_set_frequency(whoosh_lfo, lfo_freq);

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var tone = additive_next_sample(blade_synth);
        var whoosh_mod = f64_add(0.5, f64_mul(0.5, modulation_lfo_next_value(whoosh_lfo)));
        var whoosh = f64_mul(f64_mul(noise_next_sample(noise), whoosh_mod), 0.2);
        var duct = 0;
        if (duct_osc != 0) {
            duct = f64_mul(osc_next_sample(duct_osc), 0.15);
        }
        var s = f64_add(f64_add(f64_mul(tone, amp), whoosh), duct);
        vec_set(out, i, s);
        i = i + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_turbine_rpm(self) { return GhTurbine_rpm(self); }
#must_use
fn ghurni_turbine_sample_rate(self) { return GhTurbine_sample_rate(self); }

# --- clock.cyr ---

# clock.cyr -- clock and precision mechanism sound synthesis.
# Ports rust-old/src/clock.rs (ClockType enum + Clock synth). Models the
# tick-tock of escapements, spring resonance, and the delicate mechanical
# sounds of horology as periodic tick impulses shaped by a band-pass body
# resonance with an exponential ring decay.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, GHURNI_DB_SCALE,
# ghurni_is_err, ghurni_fmod), logging.cyr, dsp.cyr (GhDcBlocker + validation +
# naad error map) + the naad bundle (noise_*/filter_biquad_*/db_to_amplitude)
# + stdlib alloc/vec/math. No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness), matching engine.cyr.
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - The single naad constructor (band-pass body filter) returns a heap pointer
#   on success or a negative ERR_* code on bad params; ghurni_is_err()
#   distinguishes them. new() maps any failure to GH_ERR_SYNTHESIS_FAILED
#   (ports the Rust `.map_err(SynthesisFailed)`). noise_new never errors.
# - The tick rate is fixed by clock type, not RPM-driven: set_rpm is a NO-OP and
#   rpm() reports tick_rate*60 for interface compatibility (matches the Rust
#   Synthesizer impl).
# - serde: Clock held opaque naad backend pointers; deep #[derive(Serialize)]
#   is dropped (the integration tests only roundtrip ClockType + GhurniError,
#   which ARE supported -- see ghurni_clocktype_name/_from_name below).

# ================================================================
# ClockType (was `enum ClockType`). One per Rust variant, in order.
# ================================================================
var GH_CLOCK_WRISTWATCH        = 0;   # tiny, high-frequency tick, metallic
var GH_CLOCK_WALL_CLOCK        = 1;   # medium tick, wood resonance body
var GH_CLOCK_GRANDFATHER_CLOCK = 2;   # deep tick, large pendulum, wood case
var GH_CLOCK_POCKET_WATCH      = 3;   # small, bright, metallic case

# Externally-tagged serde variant name (parity with serde_json).
#must_use
fn ghurni_clocktype_name(t) {
    if (t == GH_CLOCK_WRISTWATCH)        { return "Wristwatch"; }
    if (t == GH_CLOCK_WALL_CLOCK)        { return "WallClock"; }
    if (t == GH_CLOCK_GRANDFATHER_CLOCK) { return "GrandfatherClock"; }
    if (t == GH_CLOCK_POCKET_WATCH)      { return "PocketWatch"; }
    return "Unknown";
}
#must_use
fn ghurni_clocktype_from_name(s) {
    if (streq(s, "Wristwatch") == 1)       { return GH_CLOCK_WRISTWATCH; }
    if (streq(s, "WallClock") == 1)        { return GH_CLOCK_WALL_CLOCK; }
    if (streq(s, "GrandfatherClock") == 1) { return GH_CLOCK_GRANDFATHER_CLOCK; }
    if (streq(s, "PocketWatch") == 1)      { return GH_CLOCK_POCKET_WATCH; }
    return (0 - 1);
}

# ================================================================
# GhClock. Accessor fields carry a mix of ints, f64 bit patterns, and heap
# pointers (dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   clock_type(int) tick_rate(f64 ticks/sec) sample_rate(f64)
#   sample_position(int) dc_blocker(ptr GhDcBlocker)
#   noise_gen(ptr naad NoiseGenerator) body_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhClock {
    clock_type;
    tick_rate;
    sample_rate;
    sample_position;
    dc_blocker;
    noise_gen;
    body_filter;
}

# tick_rate (ticks/sec) by clock type. Wristwatch 8, WallClock 2,
# GrandfatherClock 1, PocketWatch 5.
#must_use
fn ghurni_clock_tick_rate_for(clock_type) {
    if (clock_type == GH_CLOCK_WRISTWATCH)        { return f64_from(8); }
    if (clock_type == GH_CLOCK_WALL_CLOCK)        { return f64_from(2); }
    if (clock_type == GH_CLOCK_GRANDFATHER_CLOCK) { return f64_from(1); }
    if (clock_type == GH_CLOCK_POCKET_WATCH)      { return f64_from(5); }
    return f64_from(1);
}

# body resonance (Hz) by clock type -- band-pass center frequency.
#must_use
fn ghurni_clock_resonance_for(clock_type) {
    if (clock_type == GH_CLOCK_WRISTWATCH)        { return f64_from(6000); }
    if (clock_type == GH_CLOCK_WALL_CLOCK)        { return f64_from(2000); }
    if (clock_type == GH_CLOCK_GRANDFATHER_CLOCK) { return f64_from(800); }
    if (clock_type == GH_CLOCK_POCKET_WATCH)      { return f64_from(4500); }
    return f64_from(800);
}

# ring decay time constant by clock type.
#must_use
fn ghurni_clock_decay_for(clock_type) {
    if (clock_type == GH_CLOCK_WRISTWATCH)        { return 0.003; }
    if (clock_type == GH_CLOCK_WALL_CLOCK)        { return 0.01; }
    if (clock_type == GH_CLOCK_GRANDFATHER_CLOCK) { return 0.03; }
    if (clock_type == GH_CLOCK_POCKET_WATCH)      { return 0.005; }
    return 0.03;
}

# tick amplitude by clock type.
#must_use
fn ghurni_clock_amp_for(clock_type) {
    if (clock_type == GH_CLOCK_WRISTWATCH)        { return 0.15; }
    if (clock_type == GH_CLOCK_WALL_CLOCK)        { return 0.4; }
    if (clock_type == GH_CLOCK_GRANDFATHER_CLOCK) { return 0.6; }
    if (clock_type == GH_CLOCK_POCKET_WATCH)      { return 0.25; }
    return 0.6;
}

# new(clock_type, sample_rate) -> ptr or GH_ERR_*.
#must_use
fn ghurni_clock_new(clock_type, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var tick_rate = ghurni_clock_tick_rate_for(clock_type);
    var resonance = ghurni_clock_resonance_for(clock_type);

    var nyq = f64_mul(sample_rate, 0.49);

    # naad backend: white noise (seed = clock_type*997) + band-pass body filter.
    var noise = noise_new(NOISE_WHITE, clock_type * 997);
    var body_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_min(resonance, nyq), f64_from(8));
    if (ghurni_is_err(body_filter) == 1) { return ghurni_map_naad_error(body_filter); }

    var self = alloc(sizeof(GhClock));
    GhClock_set_clock_type(self, clock_type);
    GhClock_set_tick_rate(self, tick_rate);
    GhClock_set_sample_rate(self, sample_rate);
    GhClock_set_sample_position(self, 0);
    GhClock_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhClock_set_noise_gen(self, noise);
    GhClock_set_body_filter(self, body_filter);
    return self;
}

# set_rpm(rpm) -- NO-OP. Clock tick rate is fixed by type, not RPM-driven.
fn ghurni_clock_set_rpm(self, rpm) {
    return 0;
}

# synthesize(duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_clock_synthesize(self, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    var n = f64_to(f64_mul(GhClock_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_clock_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with clock sound, DC-block, and
# advance the sample counter.
fn ghurni_clock_process_block(self, out) {
    ghurni_clock_process_block_naad(self, out);
    var db = GhClock_dc_blocker(self);
    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        vec_set(out, i, ghurni_dcblocker_process(db, vec_get(out, i)));
        i = i + 1;
    }
    GhClock_set_sample_position(self, GhClock_sample_position(self) + n);
    return 0;
}

# The naad synthesis core (ports process_block_naad). Each tick period is one
# escapement cycle: a sharp attack impulse plus a filtered noise ring that
# decays exponentially, then a longer low-level ring tail, over a bed of very
# quiet mechanical hiss.
fn ghurni_clock_process_block_naad(self, out) {
    var sr = GhClock_sample_rate(self);
    var clock_type = GhClock_clock_type(self);
    var noise = GhClock_noise_gen(self);
    var body_filter = GhClock_body_filter(self);

    var tick_period = f64_div(sr, GhClock_tick_rate(self));
    var decay = ghurni_clock_decay_for(clock_type);
    var amp = ghurni_clock_amp_for(clock_type);

    var base_pos = GhClock_sample_position(self);

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var abs_pos = f64_from(base_pos + i);
        var phase = f64_div(ghurni_fmod(abs_pos, tick_period), tick_period);

        var tick = 0;
        if (f64_lt(phase, 0.02) == 1) {
            var t = f64_div(phase, 0.02);
            var impulse = f64_mul(f64_sub(F64_ONE, t), amp);
            var ring_excitation = f64_mul(noise_next_sample(noise), amp);
            var ring = f64_mul(filter_biquad_process_sample(body_filter, ring_excitation), db_to_amplitude(f64_mul(f64_div(f64_neg(phase), decay), GHURNI_DB_SCALE)));
            tick = f64_add(f64_mul(impulse, 0.5), ring);
        } elif (f64_lt(phase, 0.15) == 1) {
            var ring_excitation2 = f64_mul(f64_mul(noise_next_sample(noise), amp), 0.1);
            tick = f64_mul(f64_mul(filter_biquad_process_sample(body_filter, ring_excitation2), db_to_amplitude(f64_mul(f64_div(f64_neg(phase), decay), GHURNI_DB_SCALE))), 0.3);
        }

        var mech = f64_mul(f64_mul(noise_next_sample(noise), amp), 0.01);

        vec_set(out, i, f64_add(tick, mech));
        i = i + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
# rpm() reports tick_rate*60 as an equivalent "RPM"; the tick rate is fixed.
#must_use
fn ghurni_clock_rpm(self) {
    return f64_mul(GhClock_tick_rate(self), f64_from(60));
}
#must_use
fn ghurni_clock_sample_rate(self) {
    return GhClock_sample_rate(self);
}

# --- transmission.cyr ---

# transmission.cyr -- transmission / gearbox sound synthesis.
# Ports rust-old/src/transmission.rs (Transmission synth; no enum). Models gear
# mesh whine at the current ratio, synchronizer whine during shifts, and a light
# broadband mechanical hiss. Follows engine.cyr (the reference synth) in shape.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_err),
# logging.cyr, dsp.cyr (GhDcBlocker + validation + naad error map), smooth.cyr
# (GhSmoothedParam) + the naad bundle (osc_*/noise_*/filter_biquad_*) + stdlib
# alloc/vec/math. No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness), matching engine.cyr.
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - naad constructors return a heap pointer on success or a negative ERR_* code
#   on bad params; ghurni_is_err() distinguishes them. new() maps any failure to
#   GH_ERR_SYNTHESIS_FAILED (ports the Rust `.map_err(SynthesisFailed)`).
#   noise_new never errors.
# - The Rust process_block interleaved the naad synthesis directly in the sample
#   loop (no separate _naad helper), so this port keeps it inline too.
# - serde: Transmission held opaque naad backend pointers; deep #[derive(
#   Serialize)] is dropped (only enums/plain-data types roundtrip in the tests).

# ================================================================
# GhTransmission. Accessor fields carry a mix of ints, f64 bit patterns, and
# heap pointers (vecs / smoother / dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   ratios(vec<f64> gear ratios, index 0 = 1st gear)
#   output_teeth(int 8..64, teeth on the output gear -> mesh frequency)
#   current_gear(int, 0-indexed) sample_rate(f64) rpm(f64)
#   shift_remaining(int, samples of shift transient left)
#   shift_duration_samples(int, = sr*0.2 -> 200ms) sample_position(int)
#   mesh_rpm(ptr GhSmoothedParam) dc_blocker(ptr GhDcBlocker)
#   mesh_osc(ptr naad Oscillator sine) noise_gen(ptr naad NoiseGenerator white)
#   synchro_filter(ptr naad BiquadFilter band-pass 4000 Hz, q=3)
# ================================================================
#derive(accessors)
struct GhTransmission {
    ratios;
    output_teeth;
    current_gear;
    sample_rate;
    rpm;
    shift_remaining;
    shift_duration_samples;
    sample_position;
    mesh_rpm;
    dc_blocker;
    mesh_osc;
    noise_gen;
    synchro_filter;
}

# new(ratios, output_teeth, sample_rate) -> ptr or GH_ERR_*.
# - ratios: vec<f64> of gear ratios (e.g. [3.5, 2.1, 1.4, 1.0, 0.8]).
# - output_teeth: clamped to 8..64.
# - sample_rate: audio sample rate in Hz.
#must_use
fn ghurni_transmission_new(ratios, output_teeth, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var teeth = output_teeth;
    if (teeth < 8) { teeth = 8; }
    if (teeth > 64) { teeth = 64; }

    var shift_duration_samples = f64_to(f64_mul(sample_rate, 0.2));   # 200ms shift

    # naad backend: sine mesh oscillator + white noise + synchro band-pass.
    var mesh_osc = osc_new(WAVEFORM_SINE, f64_from(100), sample_rate);
    if (ghurni_is_err(mesh_osc) == 1) { return ghurni_map_naad_error(mesh_osc); }
    var noise = noise_new(NOISE_WHITE, teeth * 31);
    var synchro_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_from(4000), f64_from(3));
    if (ghurni_is_err(synchro_filter) == 1) { return ghurni_map_naad_error(synchro_filter); }

    var self = alloc(sizeof(GhTransmission));
    GhTransmission_set_ratios(self, ratios);
    GhTransmission_set_output_teeth(self, teeth);
    GhTransmission_set_current_gear(self, 0);
    GhTransmission_set_sample_rate(self, sample_rate);
    GhTransmission_set_rpm(self, 0);
    GhTransmission_set_shift_remaining(self, 0);
    GhTransmission_set_shift_duration_samples(self, shift_duration_samples);
    GhTransmission_set_sample_position(self, 0);
    GhTransmission_set_mesh_rpm(self, ghurni_smooth_new(0, 0.05, sample_rate));
    GhTransmission_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhTransmission_set_mesh_osc(self, mesh_osc);
    GhTransmission_set_noise_gen(self, noise);
    GhTransmission_set_synchro_filter(self, synchro_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 0..15000 (ports the Synthesizer::set_rpm impl).
fn ghurni_transmission_set_rpm(self, rpm) {
    GhTransmission_set_rpm(self, f64_clamp(rpm, 0, f64_from(15000)));
    return 0;
}

# shift_to(gear) -- shift to gear (0-indexed); triggers the shift transient if
# the gear index is in range.
fn ghurni_transmission_shift_to(self, gear) {
    if (gear < vec_len(GhTransmission_ratios(self))) {
        GhTransmission_set_current_gear(self, gear);
        GhTransmission_set_shift_remaining(self, GhTransmission_shift_duration_samples(self));
    }
    return 0;
}

# current_ratio() -- the ratio for the current gear, or 1.0 if out of range.
#must_use
fn ghurni_transmission_current_ratio(self) {
    var ratios = GhTransmission_ratios(self);
    var gear = GhTransmission_current_gear(self);
    if ((gear >= 0) && (gear < vec_len(ratios))) {
        return vec_get(ratios, gear);
    }
    return F64_ONE;
}

# output_rpm() -- output shaft RPM = rpm / current_ratio.
#must_use
#inline
fn ghurni_transmission_output_rpm(self) {
    return f64_div(GhTransmission_rpm(self), ghurni_transmission_current_ratio(self));
}

# synthesize(rpm, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_transmission_synthesize(self, rpm, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_transmission_set_rpm(self, rpm);
    var n = f64_to(f64_mul(GhTransmission_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_transmission_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with transmission sound, then
# DC-block the whole buffer. Ports the Rust process_block, which interleaves the
# naad synthesis inline (no separate _naad helper). Advances sample_position per
# sample inside the loop (matching the Rust naad-backend arm).
fn ghurni_transmission_process_block(self, out) {
    var out_rpm = ghurni_transmission_output_rpm(self);
    var mesh_rpm = GhTransmission_mesh_rpm(self);
    ghurni_smooth_set_target(mesh_rpm, out_rpm);
    var nyquist = f64_mul(GhTransmission_sample_rate(self), 0.49);

    var mesh_osc = GhTransmission_mesh_osc(self);
    var noise = GhTransmission_noise_gen(self);
    var synchro_filter = GhTransmission_synchro_filter(self);
    var teeth = f64_from(GhTransmission_output_teeth(self));
    var shift_dur = f64_from(GhTransmission_shift_duration_samples(self));

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var smooth_rpm = ghurni_smooth_next_value(mesh_rpm);
        var mesh_freq = f64_mul(f64_div(smooth_rpm, f64_from(60)), teeth);

        osc_set_frequency(mesh_osc, f64_clamp(mesh_freq, F64_ONE, nyquist));
        var mesh = f64_mul(osc_next_sample(mesh_osc), 0.15);

        # synchro whine during a shift: decaying band-passed noise envelope
        var synchro = 0;
        var shift_remaining = GhTransmission_shift_remaining(self);
        if (shift_remaining > 0) {
            shift_remaining = shift_remaining - 1;
            GhTransmission_set_shift_remaining(self, shift_remaining);
            var env = f64_div(f64_from(shift_remaining), shift_dur);
            var raw = f64_mul(f64_mul(noise_next_sample(noise), env), 0.3);
            synchro = filter_biquad_process_sample(synchro_filter, raw);
        }

        var hiss = f64_mul(noise_next_sample(noise), 0.02);
        vec_set(out, i, f64_add(mesh, f64_add(synchro, hiss)));

        GhTransmission_set_sample_position(self, GhTransmission_sample_position(self) + 1);
        i = i + 1;
    }

    # DC-block the whole buffer.
    var db = GhTransmission_dc_blocker(self);
    var j = 0;
    while (j < n) {
        vec_set(out, j, ghurni_dcblocker_process(db, vec_get(out, j)));
        j = j + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_transmission_rpm(self) { return GhTransmission_rpm(self); }
#must_use
fn ghurni_transmission_sample_rate(self) { return GhTransmission_sample_rate(self); }

# --- differential.cyr ---

# differential.cyr -- differential (final drive) sound synthesis.
# Ports rust-old/src/differential.rs (Differential synth). Models the
# characteristic whine of hypoid gear mesh in the differential, distinct from
# transmission gears. This module has NO enum -- ring/pinion tooth counts +
# RPM parameterize it.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_err),
# dsp.cyr (GhDcBlocker + validation + naad error map), smooth.cyr
# (GhSmoothedParam) + the naad bundle (osc_*/noise_*/filter_biquad_*) + stdlib
# alloc/vec/math. No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad's NoiseGenerator owns the randomness), matching engine.cyr.
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - naad constructors return a heap pointer on success or a negative ERR_* code
#   on bad params; ghurni_is_err() distinguishes them. new() maps any failure to
#   GH_ERR_SYNTHESIS_FAILED (ports the Rust `.map_err(SynthesisFailed)`).
#   noise_new never errors.
# - The Rust process_block inlines its naad synthesis core (no separate
#   process_block_naad fn); the port keeps that inline shape.

# ================================================================
# GhDifferential. Accessor fields carry a mix of ints, f64 bit patterns, and
# heap pointers (smoother / dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   ring_teeth(int, clamp 20..80) pinion_teeth(int, clamp 4..30)
#   sample_rate(f64) rpm(f64) sample_position(int)
#   smooth_rpm(ptr GhSmoothedParam) dc_blocker(ptr GhDcBlocker)
#   whine_osc(ptr naad Oscillator) noise_gen(ptr naad NoiseGenerator)
#   resonance_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhDifferential {
    ring_teeth;
    pinion_teeth;
    sample_rate;
    rpm;
    sample_position;
    smooth_rpm;
    dc_blocker;
    whine_osc;
    noise_gen;
    resonance_filter;
}

# new(ring_teeth, pinion_teeth, sample_rate) -> ptr or GH_ERR_*.
# - ring_teeth: teeth on the ring gear (typically 35-45).
# - pinion_teeth: teeth on the pinion gear (typically 8-14).
# - sample_rate: audio sample rate in Hz.
#must_use
fn ghurni_differential_new(ring_teeth, pinion_teeth, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var ring = ring_teeth;
    if (ring < 20) { ring = 20; }
    if (ring > 80) { ring = 80; }

    var pinion = pinion_teeth;
    if (pinion < 4) { pinion = 4; }
    if (pinion > 30) { pinion = 30; }

    var nyquist = f64_mul(sample_rate, 0.49);

    # Resonant frequency of the differential housing.
    var housing_resonance = f64_min(f64_from(2500), nyquist);

    # naad backend: sine whine oscillator + white noise + high-Q band-pass.
    var whine_osc = osc_new(WAVEFORM_SINE, f64_from(100), sample_rate);
    if (ghurni_is_err(whine_osc) == 1) { return ghurni_map_naad_error(whine_osc); }
    var noise = noise_new(NOISE_WHITE, ring * 41 + pinion);
    var resonance_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, housing_resonance, f64_from(6));
    if (ghurni_is_err(resonance_filter) == 1) { return ghurni_map_naad_error(resonance_filter); }

    var self = alloc(sizeof(GhDifferential));
    GhDifferential_set_ring_teeth(self, ring);
    GhDifferential_set_pinion_teeth(self, pinion);
    GhDifferential_set_sample_rate(self, sample_rate);
    GhDifferential_set_rpm(self, 0);
    GhDifferential_set_sample_position(self, 0);
    GhDifferential_set_smooth_rpm(self, ghurni_smooth_new(0, 0.05, sample_rate));
    GhDifferential_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhDifferential_set_whine_osc(self, whine_osc);
    GhDifferential_set_noise_gen(self, noise);
    GhDifferential_set_resonance_filter(self, resonance_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 0..50000.
fn ghurni_differential_set_rpm(self, rpm) {
    GhDifferential_set_rpm(self, f64_clamp(rpm, 0, f64_from(50000)));
    return 0;
}

# ratio() -- gear ratio (ring/pinion).
#must_use
#inline
fn ghurni_differential_ratio(self) {
    return f64_div(f64_from(GhDifferential_ring_teeth(self)), f64_from(GhDifferential_pinion_teeth(self)));
}

# mesh_frequency(driveshaft_rpm) -- mesh frequency = (rpm/60) * pinion_teeth.
#must_use
#inline
fn ghurni_differential_mesh_frequency(self, driveshaft_rpm) {
    return f64_mul(f64_div(driveshaft_rpm, f64_from(60)), f64_from(GhDifferential_pinion_teeth(self)));
}

# synthesize(rpm, duration) -> vec<f64> or GH_ERR_* (one-shot).
#must_use
fn ghurni_differential_synthesize(self, rpm, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_differential_set_rpm(self, rpm);
    var n = f64_to(f64_mul(GhDifferential_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_differential_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with differential whine, DC-block,
# and advance the sample counter. The naad synthesis core is inlined here (as in
# the Rust oracle).
fn ghurni_differential_process_block(self, out) {
    var smooth_rpm = GhDifferential_smooth_rpm(self);
    ghurni_smooth_set_target(smooth_rpm, GhDifferential_rpm(self));
    var nyquist = f64_mul(GhDifferential_sample_rate(self), 0.49);

    var whine_osc = GhDifferential_whine_osc(self);
    var noise = GhDifferential_noise_gen(self);
    var resonance_filter = GhDifferential_resonance_filter(self);

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var smooth = ghurni_smooth_next_value(smooth_rpm);
        var mesh_freq = ghurni_differential_mesh_frequency(self, smooth);

        osc_set_frequency(whine_osc, f64_clamp(mesh_freq, F64_ONE, nyquist));
        var whine = f64_mul(osc_next_sample(whine_osc), 0.2);

        # High-Q housing resonance excited by mesh.
        var excitation = f64_mul(noise_next_sample(noise), 0.1);
        var ring = f64_mul(filter_biquad_process_sample(resonance_filter, excitation), 0.15);

        var noise_sample = f64_mul(noise_next_sample(noise), 0.02);
        vec_set(out, i, f64_add(whine, f64_add(ring, noise_sample)));
        i = i + 1;
    }

    var db = GhDifferential_dc_blocker(self);
    var j = 0;
    while (j < n) {
        vec_set(out, j, ghurni_dcblocker_process(db, vec_get(out, j)));
        j = j + 1;
    }
    GhDifferential_set_sample_position(self, GhDifferential_sample_position(self) + n);
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_differential_rpm(self) { return GhDifferential_rpm(self); }
#must_use
fn ghurni_differential_sample_rate(self) { return GhDifferential_sample_rate(self); }

# --- forced_induction.cyr ---

# forced_induction.cyr -- turbocharger and supercharger sound synthesis.
# Ports rust-old/src/forced_induction.rs (InductionType enum + ForcedInduction
# synth). Models the whine of forced induction systems: turbo spool with
# lag/inertia, supercharger direct-drive whine, and blow-off valve bursts.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_err),
# logging.cyr, dsp.cyr (GhDcBlocker + validation + naad error map), smooth.cyr
# (GhSmoothedParam), traits.cyr (GH_KIND_FORCED_INDUCTION) + the naad bundle
# (osc_*/noise_*/filter_biquad_*) + stdlib alloc/vec/math. No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness), matching engine.cyr.
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - naad constructors return a heap pointer on success or a negative ERR_* code
#   on bad params; ghurni_is_err() distinguishes them. new() maps any failure to
#   GH_ERR_SYNTHESIS_FAILED (ports the Rust `.map_err(SynthesisFailed)`). The
#   noise generator never errors.
# - serde: ForcedInduction held opaque naad backend pointers; deep
#   #[derive(Serialize)] is dropped. Serde is provided only for InductionType
#   (roundtrip tested on Turbo) via ghurni_inductiontype_name/_from_name below.

# ================================================================
# InductionType (was `enum InductionType`). One per Rust variant, in order.
# ================================================================
var GH_INDUCTION_TURBO        = 0;   # exhaust-driven, has spool lag
var GH_INDUCTION_SUPERCHARGER = 1;   # belt-driven, direct RPM coupling

# Externally-tagged serde variant name (parity with serde_json).
#must_use
fn ghurni_inductiontype_name(t) {
    if (t == GH_INDUCTION_TURBO)        { return "Turbo"; }
    if (t == GH_INDUCTION_SUPERCHARGER) { return "Supercharger"; }
    return "Unknown";
}
#must_use
fn ghurni_inductiontype_from_name(s) {
    if (streq(s, "Turbo") == 1)        { return GH_INDUCTION_TURBO; }
    if (streq(s, "Supercharger") == 1) { return GH_INDUCTION_SUPERCHARGER; }
    return (0 - 1);
}

# ================================================================
# GhForcedInduction. Accessor fields carry a mix of ints, f64 bit patterns, and
# heap pointers (smoother / dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   induction_type(int) drive_ratio(f64, 0.5..10) spool_inertia(f64 sec)
#   sample_rate(f64) rpm(f64) load(f64) bov_active(int 0/1)
#   bov_remaining(int samples) sample_position(int)
#   spool_rpm(ptr GhSmoothedParam) dc_blocker(ptr GhDcBlocker)
#   whine_osc(ptr naad Oscillator) noise_gen(ptr naad NoiseGenerator)
#   bov_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhForcedInduction {
    induction_type;
    drive_ratio;
    spool_inertia;
    sample_rate;
    rpm;
    load;
    bov_active;
    bov_remaining;
    sample_position;
    spool_rpm;
    dc_blocker;
    whine_osc;
    noise_gen;
    bov_filter;
}

# new(induction_type, drive_ratio, spool_inertia, sample_rate) -> ptr or GH_ERR_*.
# drive_ratio clamps to 0.5..10; spool_inertia clamps to 0.1..5 for a turbo but
# is forced to 0.01 (near-instant response) for a supercharger.
#must_use
fn ghurni_forced_induction_new(induction_type, drive_ratio, spool_inertia, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var ratio = f64_clamp(drive_ratio, 0.5, f64_from(10));

    var inertia = 0.01;
    if (induction_type == GH_INDUCTION_TURBO) {
        inertia = f64_clamp(spool_inertia, 0.1, f64_from(5));
    }

    # naad backend: saw whine oscillator + white noise + band-pass BOV filter.
    var whine_osc = osc_new(WAVEFORM_SAW, f64_from(100), sample_rate);
    if (ghurni_is_err(whine_osc) == 1) { return ghurni_map_naad_error(whine_osc); }
    var noise = noise_new(NOISE_WHITE, induction_type * 777);
    var bov_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_from(2000), f64_from(2));
    if (ghurni_is_err(bov_filter) == 1) { return ghurni_map_naad_error(bov_filter); }

    var self = alloc(sizeof(GhForcedInduction));
    GhForcedInduction_set_induction_type(self, induction_type);
    GhForcedInduction_set_drive_ratio(self, ratio);
    GhForcedInduction_set_spool_inertia(self, inertia);
    GhForcedInduction_set_sample_rate(self, sample_rate);
    GhForcedInduction_set_rpm(self, 0);
    GhForcedInduction_set_load(self, 0);
    GhForcedInduction_set_bov_active(self, 0);
    GhForcedInduction_set_bov_remaining(self, 0);
    GhForcedInduction_set_sample_position(self, 0);
    GhForcedInduction_set_spool_rpm(self, ghurni_smooth_new(0, inertia, sample_rate));
    GhForcedInduction_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhForcedInduction_set_whine_osc(self, whine_osc);
    GhForcedInduction_set_noise_gen(self, noise);
    GhForcedInduction_set_bov_filter(self, bov_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 0..15000, retarget the spool smoother.
# target_spool = rpm * drive_ratio * load.
fn ghurni_forced_induction_set_rpm(self, rpm) {
    var r = f64_clamp(rpm, 0, f64_from(15000));
    GhForcedInduction_set_rpm(self, r);
    var target = f64_mul(f64_mul(r, GhForcedInduction_drive_ratio(self)), GhForcedInduction_load(self));
    ghurni_smooth_set_target(GhForcedInduction_spool_rpm(self), target);
    return 0;
}

# set_load(load) -- clamp to 0..1, retarget the spool smoother, and trigger the
# blow-off valve when load drops sharply (prev>0.5, new<0.2) while the spool is
# spinning fast (current > 5000).
fn ghurni_forced_induction_set_load(self, load) {
    var prev = GhForcedInduction_load(self);
    var l = f64_clamp(load, 0, F64_ONE);
    GhForcedInduction_set_load(self, l);
    if ((f64_gt(prev, 0.5) == 1) && (f64_lt(l, 0.2) == 1) && (f64_gt(ghurni_smooth_current(GhForcedInduction_spool_rpm(self)), f64_from(5000)) == 1)) {
        ghurni_forced_induction_trigger_bov(self);
    }
    var target = f64_mul(f64_mul(GhForcedInduction_rpm(self), GhForcedInduction_drive_ratio(self)), l);
    ghurni_smooth_set_target(GhForcedInduction_spool_rpm(self), target);
    return 0;
}

# trigger_bov() -- schedule a 150ms blow-off valve burst.
fn ghurni_forced_induction_trigger_bov(self) {
    GhForcedInduction_set_bov_active(self, 1);
    GhForcedInduction_set_bov_remaining(self, f64_to(f64_mul(GhForcedInduction_sample_rate(self), 0.15)));
    return 0;
}

# synthesize(rpm, load, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_forced_induction_synthesize(self, rpm, load, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_forced_induction_set_rpm(self, rpm);
    ghurni_forced_induction_set_load(self, load);
    var n = f64_to(f64_mul(GhForcedInduction_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_forced_induction_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with induction sound, DC-block, and
# advance the sample counter.
fn ghurni_forced_induction_process_block(self, out) {
    ghurni_forced_induction_process_block_naad(self, out);
    var db = GhForcedInduction_dc_blocker(self);
    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        vec_set(out, i, ghurni_dcblocker_process(db, vec_get(out, i)));
        i = i + 1;
    }
    GhForcedInduction_set_sample_position(self, GhForcedInduction_sample_position(self) + n);
    return 0;
}

# The naad synthesis core (ports process_block_naad).
fn ghurni_forced_induction_process_block_naad(self, out) {
    var sr = GhForcedInduction_sample_rate(self);
    var nyquist = f64_mul(sr, 0.49);
    var spool_rpm = GhForcedInduction_spool_rpm(self);
    var whine_osc = GhForcedInduction_whine_osc(self);
    var noise = GhForcedInduction_noise_gen(self);
    var bov_filter = GhForcedInduction_bov_filter(self);

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var spool = ghurni_smooth_next_value(spool_rpm);
        var whine_freq = f64_clamp(f64_div(spool, f64_from(60)), f64_from(20), nyquist);
        osc_set_frequency(whine_osc, whine_freq);

        # whine amplitude scales with spool speed
        var whine_amp = f64_clamp(f64_div(spool, f64_from(20000)), 0, 0.4);
        var whine = f64_mul(osc_next_sample(whine_osc), whine_amp);

        # compressor noise -- broadband hiss proportional to boost
        var hiss = f64_mul(f64_mul(noise_next_sample(noise), whine_amp), 0.15);

        # BOV burst
        var bov = 0;
        var rem = GhForcedInduction_bov_remaining(self);
        if (rem > 0) {
            rem = rem - 1;
            GhForcedInduction_set_bov_remaining(self, rem);
            var env = f64_div(f64_from(rem), f64_mul(sr, 0.15));
            var raw = f64_mul(f64_mul(noise_next_sample(noise), env), 0.6);
            bov = filter_biquad_process_sample(bov_filter, raw);
        } else {
            GhForcedInduction_set_bov_active(self, 0);
        }

        var s = f64_add(whine, f64_add(hiss, bov));
        vec_set(out, i, s);
        i = i + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_forced_induction_rpm(self) { return GhForcedInduction_rpm(self); }
#must_use
fn ghurni_forced_induction_sample_rate(self) { return GhForcedInduction_sample_rate(self); }

# --- belt_drive.cyr ---

# belt_drive.cyr -- belt drive sound synthesis.
# Ports rust-old/src/belt_drive.rs (BeltDrive synth). Models serpentine / timing
# belt squeal and flap, driven by pulley RPM and belt tension: a tension-dependent
# high-frequency squeal oscillator plus band-pass-filtered pink noise flap, both
# amplitude-modulated at the belt's rotation rate.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_err),
# logging.cyr, dsp.cyr (GhDcBlocker + validation + naad error map), smooth.cyr
# (GhSmoothedParam) + the naad bundle (osc_*/noise_*/filter_biquad_*) + stdlib
# alloc/vec/math (F64_PI/F64_TAU). No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng/math) is dropped
#   (naad owns the randomness via its NoiseGenerator).
# - naad constructors (osc / filter) return a heap pointer on success or a
#   negative ERR_* code on bad params; ghurni_is_err() distinguishes them and
#   new() maps failures to GH_ERR_SYNTHESIS_FAILED (ports `.map_err`). noise_new
#   never errors.
# - serde: BeltDrive held opaque naad backend pointers; deep #[derive(Serialize)]
#   is dropped. There is no public enum to roundtrip for this module.
# - process_block interleaves the naad synthesis inline (no separate _naad fn) --
#   mirrors the Rust, whose belt process_block bodies the naad loop directly.
# - Rust `noise_gen` seed = `pulley_diameter.to_bits() + tension.to_bits()`;
#   the port derives a behavioral integer seed (bit-exactness is not meaningful).

# ================================================================
# GhBeltDrive. Accessor fields carry a mix of ints, f64 bit patterns, and heap
# pointers (smoother / dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   pulley_diameter(f64 mm, clamp 20..500) tension(f64 0..1) sample_rate(f64)
#   rpm(f64) sample_position(int) smooth_rpm(ptr GhSmoothedParam)
#   dc_blocker(ptr GhDcBlocker) squeal_osc(ptr naad Oscillator)
#   noise_gen(ptr naad NoiseGenerator) flap_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhBeltDrive {
    pulley_diameter;
    tension;
    sample_rate;
    rpm;
    sample_position;
    smooth_rpm;
    dc_blocker;
    squeal_osc;
    noise_gen;
    flap_filter;
}

# new(pulley_diameter, tension, sample_rate) -> ptr or GH_ERR_*.
# pulley_diameter clamps to 20..500 (mm), tension to 0..1.
#must_use
fn ghurni_belt_drive_new(pulley_diameter, tension, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var diameter = f64_clamp(pulley_diameter, f64_from(20), f64_from(500));
    var tens = f64_clamp(tension, 0, F64_ONE);
    var nyq = f64_mul(sample_rate, 0.49);

    # Squeal frequency depends on belt speed and tension (2000..5000 Hz).
    var squeal_freq = f64_min(f64_add(f64_from(2000), f64_mul(f64_sub(F64_ONE, tens), f64_from(3000))), nyq);

    # naad backend: squeal oscillator + pink noise + band-pass flap filter.
    var squeal_osc = osc_new(WAVEFORM_SINE, squeal_freq, sample_rate);
    if (ghurni_is_err(squeal_osc) == 1) { return ghurni_map_naad_error(squeal_osc); }
    var noise = noise_new(NOISE_PINK, f64_to(diameter) + f64_to(tens));
    var flap_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_from(500), f64_from(2));
    if (ghurni_is_err(flap_filter) == 1) { return ghurni_map_naad_error(flap_filter); }

    var self = alloc(sizeof(GhBeltDrive));
    GhBeltDrive_set_pulley_diameter(self, diameter);
    GhBeltDrive_set_tension(self, tens);
    GhBeltDrive_set_sample_rate(self, sample_rate);
    GhBeltDrive_set_rpm(self, 0);
    GhBeltDrive_set_sample_position(self, 0);
    GhBeltDrive_set_smooth_rpm(self, ghurni_smooth_new(0, 0.03, sample_rate));
    GhBeltDrive_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhBeltDrive_set_squeal_osc(self, squeal_osc);
    GhBeltDrive_set_noise_gen(self, noise);
    GhBeltDrive_set_flap_filter(self, flap_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 0..20000.
fn ghurni_belt_drive_set_rpm(self, rpm) {
    GhBeltDrive_set_rpm(self, f64_clamp(rpm, 0, f64_from(20000)));
    return 0;
}

# set_tension(tension) -- clamp to 0..1 (0 = slack/squealy, 1 = tight/quiet).
fn ghurni_belt_drive_set_tension(self, tension) {
    GhBeltDrive_set_tension(self, f64_clamp(tension, 0, F64_ONE));
    return 0;
}

# belt_speed(rpm) -- belt linear speed in m/s. v = PI * d * RPM / 60000
# (d in mm -> m).
#must_use
#inline
fn ghurni_belt_drive_belt_speed(self, rpm) {
    return f64_div(f64_mul(f64_mul(F64_PI, GhBeltDrive_pulley_diameter(self)), rpm), f64_from(60000));
}

# synthesize(rpm, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_belt_drive_synthesize(self, rpm, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_belt_drive_set_rpm(self, rpm);
    var n = f64_to(f64_mul(GhBeltDrive_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_belt_drive_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with belt drive sound. The naad
# synthesis is interleaved inline (mirrors the Rust); then DC-block and advance
# the sample counter.
fn ghurni_belt_drive_process_block(self, out) {
    var smooth_rpm = GhBeltDrive_smooth_rpm(self);
    var rpm = GhBeltDrive_rpm(self);
    ghurni_smooth_set_target(smooth_rpm, rpm);

    var sr = GhBeltDrive_sample_rate(self);
    var tens = GhBeltDrive_tension(self);
    var nyq = f64_mul(sr, 0.49);

    # Squeal amplitude inversely proportional to tension.
    var squeal_amp = f64_mul(f64_sub(F64_ONE, tens), 0.3);
    # Flap depends on belt speed.
    var speed = ghurni_belt_drive_belt_speed(self, rpm);
    var flap_amp = f64_clamp(f64_div(speed, f64_from(20)), 0, 0.2);

    # Belt rotation frequency (one full loop). circumference in meters.
    var belt_circumference = f64_div(f64_mul(F64_PI, GhBeltDrive_pulley_diameter(self)), f64_from(1000));
    var belt_rotation_freq = 0;
    if (f64_gt(belt_circumference, 0) == 1) {
        belt_rotation_freq = f64_div(speed, f64_max(belt_circumference, 0.1));
    }

    var osc = GhBeltDrive_squeal_osc(self);
    var noise = GhBeltDrive_noise_gen(self);
    var flap_filter = GhBeltDrive_flap_filter(self);
    var base_pos = GhBeltDrive_sample_position(self);

    # squeal frequency (constant across the block), clamped to nyquist.
    var squeal_freq = f64_min(f64_add(f64_from(2000), f64_mul(f64_sub(F64_ONE, tens), f64_from(3000))), nyq);

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        ghurni_smooth_next_value(smooth_rpm);

        # Squeal: high-frequency friction oscillation.
        osc_set_frequency(osc, squeal_freq);
        var squeal = f64_mul(osc_next_sample(osc), squeal_amp);

        # Flap: periodic low-frequency thump from belt joints / splices.
        var raw_flap = f64_mul(noise_next_sample(noise), flap_amp);
        var flap = filter_biquad_process_sample(flap_filter, raw_flap);

        # Periodic modulation at the belt rotation rate.
        var abs_pos = f64_from(base_pos + i);
        var belt_mod = F64_ONE;
        if (f64_gt(belt_rotation_freq, 0) == 1) {
            var belt_omega = f64_div(f64_mul(F64_TAU, belt_rotation_freq), sr);
            belt_mod = f64_add(0.8, f64_mul(0.2, f64_sin(f64_mul(belt_omega, abs_pos))));
        }

        vec_set(out, i, f64_mul(f64_add(squeal, flap), belt_mod));
        i = i + 1;
    }

    var db = GhBeltDrive_dc_blocker(self);
    var j = 0;
    while (j < n) {
        vec_set(out, j, ghurni_dcblocker_process(db, vec_get(out, j)));
        j = j + 1;
    }
    GhBeltDrive_set_sample_position(self, base_pos + n);
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_belt_drive_rpm(self) { return GhBeltDrive_rpm(self); }
#must_use
fn ghurni_belt_drive_sample_rate(self) { return GhBeltDrive_sample_rate(self); }

# --- chain_drive.cyr ---

# chain_drive.cyr -- chain drive sound synthesis.
# Ports rust-old/src/chain_drive.rs (ChainDrive synth; no enum). Models the
# periodic rattle/clank of chain links engaging sprocket teeth (motorcycles,
# bicycles, industrial machinery): a sharp impact impulse at each link
# engagement plus a low-level broadband rattle, DC-blocked.
#
# Requires (from the build/test unit): error.cyr (GH_ERR_*, ghurni_is_err,
# ghurni_fmod), logging.cyr, dsp.cyr (GhDcBlocker + validation + naad error
# map), smooth.cyr (GhSmoothedParam) + the naad bundle (noise_*/
# filter_biquad_*) + stdlib alloc/vec/math. No `include` lines.
#
# PORT NOTES
# - f32 -> f64 throughout. The Rust `naad-backend` (default) path is the ONE
#   ported path; the `#[cfg(not(naad-backend))]` fallback (rng) is dropped
#   (naad owns the randomness), matching engine.cyr.
# - No enum -> no serde name helpers (ChainDrive itself held opaque naad
#   pointers, so its deep #[derive(Serialize)] is dropped like engine.cyr).
# - Audio buffers are stdlib vecs of f64. process_block fills a caller vec in
#   place; synthesize allocates + returns one.
# - Rust interleaved the per-sample synthesis inside process_block; the port
#   splits it into a naad core (ghurni_chain_drive_process_block_naad) called
#   by process_block, then DC-blocks + advances the sample counter (engine.cyr
#   shape). Rust `abs_pos % engage_period` (both >= 0) -> ghurni_fmod.
# - links clamp 10..500, sprocket_teeth clamp 4..64; set_rpm clamps 0..30000.

# ================================================================
# GhChainDrive. Accessor fields carry a mix of ints, f64 bit patterns, and heap
# pointers (smoother / dc blocker / naad objects), all i64-wide.
# NOTE: struct bodies must NOT contain inline `#` comments (parser limitation);
# field roles are documented here instead:
#   links(int 10..500) sprocket_teeth(int 4..64) sample_rate(f64) rpm(f64)
#   sample_position(int) smooth_rpm(ptr GhSmoothedParam)
#   dc_blocker(ptr GhDcBlocker) noise_gen(ptr naad NoiseGenerator)
#   impact_filter(ptr naad BiquadFilter)
# ================================================================
#derive(accessors)
struct GhChainDrive {
    links;
    sprocket_teeth;
    sample_rate;
    rpm;
    sample_position;
    smooth_rpm;
    dc_blocker;
    noise_gen;
    impact_filter;
}

# new(links, sprocket_teeth, sample_rate) -> ptr or GH_ERR_*.
#must_use
fn ghurni_chain_drive_new(links, sprocket_teeth, sample_rate) {
    var vsr = ghurni_validate_sample_rate(sample_rate);
    if (ghurni_is_err(vsr) == 1) { return vsr; }

    var lk = links;
    if (lk < 10) { lk = 10; }
    if (lk > 500) { lk = 500; }
    var st = sprocket_teeth;
    if (st < 4) { st = 4; }
    if (st > 64) { st = 64; }

    var nyq = f64_mul(sample_rate, 0.49);

    # naad backend: white noise + band-pass impact filter (3 kHz, q=3).
    var noise = noise_new(NOISE_WHITE, lk * 17 + st);
    var impact_filter = filter_biquad_new(FILTER_BANDPASS, sample_rate, f64_min(f64_from(3000), nyq), f64_from(3));
    if (ghurni_is_err(impact_filter) == 1) { return ghurni_map_naad_error(impact_filter); }

    var self = alloc(sizeof(GhChainDrive));
    GhChainDrive_set_links(self, lk);
    GhChainDrive_set_sprocket_teeth(self, st);
    GhChainDrive_set_sample_rate(self, sample_rate);
    GhChainDrive_set_rpm(self, 0);
    GhChainDrive_set_sample_position(self, 0);
    GhChainDrive_set_smooth_rpm(self, ghurni_smooth_new(0, 0.03, sample_rate));
    GhChainDrive_set_dc_blocker(self, ghurni_dcblocker_new(sample_rate));
    GhChainDrive_set_noise_gen(self, noise);
    GhChainDrive_set_impact_filter(self, impact_filter);
    return self;
}

# set_rpm(rpm) -- clamp to 0..30000.
fn ghurni_chain_drive_set_rpm(self, rpm) {
    GhChainDrive_set_rpm(self, f64_clamp(rpm, 0, f64_from(30000)));
    return 0;
}

# engagement_frequency(rpm). Link engagement rate = revs/sec * sprocket_teeth.
#must_use
#inline
fn ghurni_chain_drive_engagement_frequency(self, rpm) {
    return f64_mul(f64_div(rpm, f64_from(60)), f64_from(GhChainDrive_sprocket_teeth(self)));
}

# synthesize(rpm, duration) -> vec<f64> or GH_ERR_*.
#must_use
fn ghurni_chain_drive_synthesize(self, rpm, duration) {
    var vd = ghurni_validate_duration(duration);
    if (ghurni_is_err(vd) == 1) { return vd; }
    ghurni_chain_drive_set_rpm(self, rpm);
    var n = f64_to(f64_mul(GhChainDrive_sample_rate(self), duration));
    var out = vec_new();
    var i = 0;
    while (i < n) { vec_push(out, 0); i = i + 1; }
    ghurni_chain_drive_process_block(self, out);
    return out;
}

# process_block(out) -- fill `out` (vec<f64>) with chain drive sound, DC-block,
# and advance the sample counter.
fn ghurni_chain_drive_process_block(self, out) {
    ghurni_chain_drive_process_block_naad(self, out);
    var db = GhChainDrive_dc_blocker(self);
    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        vec_set(out, i, ghurni_dcblocker_process(db, vec_get(out, i)));
        i = i + 1;
    }
    GhChainDrive_set_sample_position(self, GhChainDrive_sample_position(self) + n);
    return 0;
}

# The naad synthesis core (ports the inline process_block loop). Retargets the
# smoother, then per sample: sharp impact impulse (impulse + filtered noise
# ring) in the first 5% of each engagement period, plus a low broadband rattle.
fn ghurni_chain_drive_process_block_naad(self, out) {
    var smooth_rpm = GhChainDrive_smooth_rpm(self);
    ghurni_smooth_set_target(smooth_rpm, GhChainDrive_rpm(self));

    var sr = GhChainDrive_sample_rate(self);
    var noise = GhChainDrive_noise_gen(self);
    var impact_filter = GhChainDrive_impact_filter(self);
    var base_pos = GhChainDrive_sample_position(self);

    var n = vec_len(out);
    var i = 0;
    while (i < n) {
        var smooth = ghurni_smooth_next_value(smooth_rpm);
        var engage_freq = ghurni_chain_drive_engagement_frequency(self, smooth);

        if (f64_lt(engage_freq, F64_ONE) == 1) {
            vec_set(out, i, 0);
            i = i + 1;
            continue;
        }

        var engage_period = f64_div(sr, engage_freq);
        var abs_pos = f64_from(base_pos + i);
        var phase = f64_div(ghurni_fmod(abs_pos, engage_period), engage_period);

        # Sharp impact at each link engagement (first 5% of the period).
        var impact = 0;
        if (f64_lt(phase, 0.05) == 1) {
            var t = f64_div(phase, 0.05);
            var impulse = f64_mul(f64_sub(F64_ONE, t), 0.3);
            var ring = f64_mul(noise_next_sample(noise), f64_sub(F64_ONE, t));
            impact = f64_add(impulse, f64_mul(filter_biquad_process_sample(impact_filter, ring), 0.2));
        }

        var rattle = f64_mul(noise_next_sample(noise), 0.03);
        vec_set(out, i, f64_add(impact, rattle));
        i = i + 1;
    }
    return 0;
}

# Synthesizer-trait accessors (used by the mixer's tag dispatch + parity).
#must_use
fn ghurni_chain_drive_rpm(self) { return GhChainDrive_rpm(self); }
#must_use
fn ghurni_chain_drive_sample_rate(self) { return GhChainDrive_sample_rate(self); }

# --- mixer.cyr ---

# mixer.cyr -- multi-component mechanical sound mixer.
# Ports rust-old/src/mixer.rs (MixerChannel + MechanicalMixer). Combines several
# synths into one output with independent gain / pan / mute per channel.
#
# The Rust mixer stored `Box<dyn Synthesizer>` per channel. Cyrius has no trait
# objects (ADR-004), so each channel carries a (GH_KIND_* tag, synth pointer)
# pair and the tag-dispatch helpers below (ghurni_synth_process_block /
# ghurni_synth_set_rpm) switch on the tag to call the concrete synth method.
# This is the hand-written equivalent of the trait's vtable.
#
# Requires (from the build/test unit): traits.cyr (GH_KIND_*), every synth
# module (their process_block / set_rpm), math (f64_*, F64_PI_2) + stdlib
# alloc/vec. No `include` lines.
#
# serde: MixerChannel/MechanicalMixer were Serialize with #[serde(skip)] on the
# synth + scratch (the live synth objects can't serialize). Deep serde is
# dropped in the port (nothing meaningful survives the skip); the structs use
# #derive(accessors) only.

# ================================================================
# Tag dispatch -- the Synthesizer "vtable". Switches a (kind, synth) pair to the
# concrete synth's method. Forward-references every synth's fns (resolved across
# the whole compilation unit).
# ================================================================
fn ghurni_synth_process_block(kind, synth, out) {
    if (kind == GH_KIND_ENGINE)             { ghurni_engine_process_block(synth, out); }
    elif (kind == GH_KIND_GEAR)             { ghurni_gear_process_block(synth, out); }
    elif (kind == GH_KIND_MOTOR)            { ghurni_motor_process_block(synth, out); }
    elif (kind == GH_KIND_TURBINE)          { ghurni_turbine_process_block(synth, out); }
    elif (kind == GH_KIND_CLOCK)            { ghurni_clock_process_block(synth, out); }
    elif (kind == GH_KIND_TRANSMISSION)     { ghurni_transmission_process_block(synth, out); }
    elif (kind == GH_KIND_DIFFERENTIAL)     { ghurni_differential_process_block(synth, out); }
    elif (kind == GH_KIND_FORCED_INDUCTION) { ghurni_forced_induction_process_block(synth, out); }
    elif (kind == GH_KIND_BELT_DRIVE)       { ghurni_belt_drive_process_block(synth, out); }
    elif (kind == GH_KIND_CHAIN_DRIVE)      { ghurni_chain_drive_process_block(synth, out); }
    return 0;
}

fn ghurni_synth_set_rpm(kind, synth, rpm) {
    if (kind == GH_KIND_ENGINE)             { ghurni_engine_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_GEAR)             { ghurni_gear_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_MOTOR)            { ghurni_motor_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_TURBINE)          { ghurni_turbine_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_CLOCK)            { ghurni_clock_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_TRANSMISSION)     { ghurni_transmission_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_DIFFERENTIAL)     { ghurni_differential_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_FORCED_INDUCTION) { ghurni_forced_induction_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_BELT_DRIVE)       { ghurni_belt_drive_set_rpm(synth, rpm); }
    elif (kind == GH_KIND_CHAIN_DRIVE)      { ghurni_chain_drive_set_rpm(synth, rpm); }
    return 0;
}

# ================================================================
# GhMixerChannel: name(cstring ptr) gain(f64) pan(f64) muted(int 0/1)
# kind(GH_KIND_*) synth(ptr) scratch(vec<f64> or 0). GhMixer: channels(vec of
# GhMixerChannel ptrs) master_gain(f64).
# ================================================================
#derive(accessors)
struct GhMixerChannel {
    name;
    gain;
    pan;
    muted;
    kind;
    synth;
    scratch;
}

#derive(accessors)
struct GhMixer {
    channels;
    master_gain;
}

# new() -- empty mixer, unity master gain.
#must_use
fn ghurni_mixer_new() {
    var m = alloc(sizeof(GhMixer));
    GhMixer_set_channels(m, vec_new());
    GhMixer_set_master_gain(m, F64_ONE);
    return m;
}

# add_channel(name, kind, synth) -- append a channel (gain 1, pan 0, unmuted),
# return its index. (Rust took a Box<dyn Synthesizer>; the port takes the
# (kind, synth) pair.)
fn ghurni_mixer_add_channel(m, name, kind, synth) {
    var ch = alloc(sizeof(GhMixerChannel));
    GhMixerChannel_set_name(ch, name);
    GhMixerChannel_set_gain(ch, F64_ONE);
    GhMixerChannel_set_pan(ch, 0);
    GhMixerChannel_set_muted(ch, 0);
    GhMixerChannel_set_kind(ch, kind);
    GhMixerChannel_set_synth(ch, synth);
    GhMixerChannel_set_scratch(ch, 0);
    var channels = GhMixer_channels(m);
    var idx = vec_len(channels);
    vec_push(channels, ch);
    return idx;
}

# set_channel_gain(idx, gain) -- gain >= 0.
fn ghurni_mixer_set_channel_gain(m, index, gain) {
    var channels = GhMixer_channels(m);
    if ((index >= 0) && (index < vec_len(channels))) {
        GhMixerChannel_set_gain(vec_get(channels, index), f64_max(gain, 0));
    }
    return 0;
}

# set_channel_pan(idx, pan) -- pan in [-1, 1].
fn ghurni_mixer_set_channel_pan(m, index, pan) {
    var channels = GhMixer_channels(m);
    if ((index >= 0) && (index < vec_len(channels))) {
        GhMixerChannel_set_pan(vec_get(channels, index), f64_clamp(pan, f64_neg(F64_ONE), F64_ONE));
    }
    return 0;
}

# set_channel_muted(idx, muted) -- 1 = muted, 0 = active.
fn ghurni_mixer_set_channel_muted(m, index, muted) {
    var channels = GhMixer_channels(m);
    if ((index >= 0) && (index < vec_len(channels))) {
        GhMixerChannel_set_muted(vec_get(channels, index), muted);
    }
    return 0;
}

# set_master_gain(gain) -- master >= 0.
fn ghurni_mixer_set_master_gain(m, gain) {
    GhMixer_set_master_gain(m, f64_max(gain, 0));
    return 0;
}

# set_rpm(rpm) -- broadcast to every channel's synth.
fn ghurni_mixer_set_rpm(m, rpm) {
    var channels = GhMixer_channels(m);
    var n = vec_len(channels);
    var i = 0;
    while (i < n) {
        var ch = vec_get(channels, i);
        ghurni_synth_set_rpm(GhMixerChannel_kind(ch), GhMixerChannel_synth(ch), rpm);
        i = i + 1;
    }
    return 0;
}

# channel_count().
#must_use
fn ghurni_mixer_channel_count(m) {
    return vec_len(GhMixer_channels(m));
}

# Build a fresh scratch vec of exactly `len` zeros for one channel (Cyrius vecs
# have no sub-slice, so process_block must see a vec of exactly `len`).
#must_use
fn ghurni_mixer_scratch(len) {
    var v = vec_new();
    var i = 0;
    while (i < len) { vec_push(v, 0); i = i + 1; }
    return v;
}

# process_block(out) -- render + sum all unmuted channels into mono `out`.
fn ghurni_mixer_process_block(m, out) {
    var len = vec_len(out);
    var z = 0;
    while (z < len) { vec_set(out, z, 0); z = z + 1; }

    var master = GhMixer_master_gain(m);
    var channels = GhMixer_channels(m);
    var nc = vec_len(channels);
    var ci = 0;
    while (ci < nc) {
        var ch = vec_get(channels, ci);
        if (GhMixerChannel_muted(ch) == 0) {
            var scratch = ghurni_mixer_scratch(len);
            GhMixerChannel_set_scratch(ch, scratch);
            ghurni_synth_process_block(GhMixerChannel_kind(ch), GhMixerChannel_synth(ch), scratch);
            var gain = f64_mul(GhMixerChannel_gain(ch), master);
            var i = 0;
            while (i < len) {
                vec_set(out, i, f64_add(vec_get(out, i), f64_mul(vec_get(scratch, i), gain)));
                i = i + 1;
            }
        }
        ci = ci + 1;
    }
    return 0;
}

# process_block_stereo(left, right) -- equal-power pan into stereo.
fn ghurni_mixer_process_block_stereo(m, left, right) {
    var len = vec_len(left);
    if (vec_len(right) < len) { len = vec_len(right); }
    var z = 0;
    while (z < len) { vec_set(left, z, 0); vec_set(right, z, 0); z = z + 1; }

    var master = GhMixer_master_gain(m);
    var channels = GhMixer_channels(m);
    var nc = vec_len(channels);
    var ci = 0;
    while (ci < nc) {
        var ch = vec_get(channels, ci);
        if (GhMixerChannel_muted(ch) == 0) {
            var scratch = ghurni_mixer_scratch(len);
            GhMixerChannel_set_scratch(ch, scratch);
            ghurni_synth_process_block(GhMixerChannel_kind(ch), GhMixerChannel_synth(ch), scratch);
            # equal-power pan law
            var pan_norm = f64_mul(f64_add(GhMixerChannel_pan(ch), F64_ONE), 0.5);
            var angle = f64_mul(pan_norm, F64_PI_2);
            var gain = f64_mul(GhMixerChannel_gain(ch), master);
            var gain_l = f64_mul(f64_cos(angle), gain);
            var gain_r = f64_mul(f64_sin(angle), gain);
            var i = 0;
            while (i < len) {
                var s = vec_get(scratch, i);
                vec_set(left, i, f64_add(vec_get(left, i), f64_mul(s, gain_l)));
                vec_set(right, i, f64_add(vec_get(right, i), f64_mul(s, gain_r)));
                i = i + 1;
            }
        }
        ci = ci + 1;
    }
    return 0;
}

# --- presets.cyr ---

# presets.cyr -- shipped presets for common mechanical configurations.
# Ports rust-old/src/presets.rs. Each preset builds a fully configured synth
# with realistic parameters; all take a sample_rate. Returns a synth pointer or
# a negative GH_ERR_* code (propagated from the underlying constructor).
#
# Requires (from the build/test unit): the engine / motor / turbine /
# transmission / gear / forced_induction synth modules + their enum constants,
# stdlib alloc/vec. No `include` lines.

# V8 muscle car -- cross-plane firing order, deep exhaust.
#must_use
fn ghurni_preset_v8_muscle_car(sample_rate) {
    var engine = ghurni_engine_new(GH_ENGINE_GASOLINE, 8, sample_rate);
    if (ghurni_is_err(engine) == 1) { return engine; }
    var order = vec_new();
    vec_push(order, f64_from(0));   vec_push(order, f64_from(90));
    vec_push(order, f64_from(270)); vec_push(order, f64_from(180));
    vec_push(order, f64_from(540)); vec_push(order, f64_from(630));
    vec_push(order, f64_from(450)); vec_push(order, f64_from(360));
    ghurni_engine_set_firing_order(engine, order);
    ghurni_engine_set_rpm(engine, f64_from(800));
    ghurni_engine_set_load(engine, 0.1);
    return engine;
}

# Inline-4 economy car -- even firing, smooth tone.
#must_use
fn ghurni_preset_inline4_economy(sample_rate) {
    return ghurni_engine_new(GH_ENGINE_GASOLINE, 4, sample_rate);
}

# Diesel truck engine -- 6 cylinder, rough, low RPM.
#must_use
fn ghurni_preset_diesel_truck(sample_rate) {
    var engine = ghurni_engine_new(GH_ENGINE_DIESEL, 6, sample_rate);
    if (ghurni_is_err(engine) == 1) { return engine; }
    ghurni_engine_set_rpm(engine, f64_from(700));
    ghurni_engine_set_load(engine, 0.2);
    return engine;
}

# Single-cylinder motorcycle (2-stroke).
#must_use
fn ghurni_preset_motorcycle_single(sample_rate) {
    return ghurni_engine_new(GH_ENGINE_TWO_STROKE, 1, sample_rate);
}

# Electric vehicle motor -- brushless, smooth, high-RPM capable.
#must_use
fn ghurni_preset_electric_vehicle(sample_rate) {
    return ghurni_motor_new(GH_MOTOR_BRUSHLESS, 8, sample_rate);
}

# Turbocharger with moderate spool lag.
#must_use
fn ghurni_preset_turbocharger(sample_rate) {
    return ghurni_forced_induction_new(GH_INDUCTION_TURBO, 2.5, F64_ONE, sample_rate);
}

# Supercharger -- belt-driven, instant response.
#must_use
fn ghurni_preset_supercharger(sample_rate) {
    return ghurni_forced_induction_new(GH_INDUCTION_SUPERCHARGER, 1.5, 0.01, sample_rate);
}

# 5-speed manual transmission.
#must_use
fn ghurni_preset_manual_5speed(sample_rate) {
    var ratios = vec_new();
    vec_push(ratios, 3.5); vec_push(ratios, 2.1); vec_push(ratios, 1.4);
    vec_push(ratios, F64_ONE); vec_push(ratios, 0.8);
    return ghurni_transmission_new(ratios, 24, sample_rate);
}

# 6-speed manual transmission (close-ratio).
#must_use
fn ghurni_preset_manual_6speed(sample_rate) {
    var ratios = vec_new();
    vec_push(ratios, 3.8); vec_push(ratios, 2.3); vec_push(ratios, 1.6);
    vec_push(ratios, 1.2); vec_push(ratios, 0.95); vec_push(ratios, 0.78);
    return ghurni_transmission_new(ratios, 28, sample_rate);
}

# Steel spur gear -- bright metallic mesh.
#must_use
fn ghurni_preset_steel_spur_gear(teeth, sample_rate) {
    return ghurni_gear_new(teeth, GH_GEAR_STEEL, sample_rate);
}

# Industrial turbine -- 24-blade ducted.
#must_use
fn ghurni_preset_industrial_turbine(sample_rate) {
    return ghurni_turbine_new(24, f64_from(600), sample_rate);
}

# Propeller -- 3-blade open (no duct).
#must_use
fn ghurni_preset_propeller(sample_rate) {
    return ghurni_turbine_new(3, 0, sample_rate);
}
